    <div class="grid grid-cols-2 md:grid-cols-5 gap-3">
      <div class="bg-white/[0.03] border border-white/10 rounded-xl p-4">
        <div class="text-[10px] uppercase tracking-[0.14em] text-white/40 font-bold mb-1">Critical</div>
