  <BlocksterV2Web.DocsComponents.docs_hero
    eyebrow="Security · Audit report"
    title="Blockster Bankroll — security audit."
    description="An independent, line-by-line review of the Anchor program that backs Blockster's coin flip game and dual-vault liquidity pools. 22 instructions, 7 account structs, 32 error codes, roughly 1,200 lines of Rust."
  />

  <div class="not-prose my-8 rounded-2xl bg-[#0A0F1C] text-white p-6 md:p-8">
    <div class="flex items-center justify-between gap-4 flex-wrap mb-6">
      <div>
