        <div class="font-haas_bold_75 text-[22px] leading-tight">Blockster Bankroll v1</div>
        <div class="text-[13px] text-white/55 font-mono mt-1">Program 49up2uzZANpjTC3sgggbZazdHBii2vY9mVK3vk5dT2tm</div>
      </div>
      <div class="flex flex-col items-end gap-1 text-[11px] text-white/60 font-mono">
