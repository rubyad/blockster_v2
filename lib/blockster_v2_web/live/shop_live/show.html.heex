<BlocksterV2Web.DesignSystem.header
  current_user={@current_user}
  active="shop"
  bux_balance={Map.get(assigns, :bux_balance, 0)}
  token_balances={Map.get(assigns, :token_balances, %{})}
  cart_item_count={Map.get(assigns, :cart_item_count, 0)}
  unread_notification_count={Map.get(assigns, :unread_notification_count, 0)}
  notification_dropdown_open={Map.get(assigns, :notification_dropdown_open, false)}
  recent_notifications={Map.get(assigns, :recent_notifications, [])}
  search_query={Map.get(assigns, :search_query, "")}
  search_results={Map.get(assigns, :search_results, [])}
  show_search_results={Map.get(assigns, :show_search_results, false)}
  show_search_modal={Map.get(assigns, :show_search_modal, false)}
  connecting={Map.get(assigns, :connecting, false)}
  show_why_earn_bux={true}
  announcement_banner={assigns[:announcement_banner]}
/>

<main class="max-w-[1280px] mx-auto px-6">

  <%!-- ── Breadcrumb ───────────────────���─────────────────────────────── --%>
  <nav class="pt-8 pb-6 flex items-center gap-2 text-[11px] text-neutral-500 font-medium" aria-label="Breadcrumb">
    <.link navigate={~p"/shop"} class="hover:text-[#141414]">Shop</.link>
    <%= if Enum.any?(@product.categories) do %>
      <span>/</span>
      <.link navigate={~p"/shop?category=#{List.first(@product.categories).slug}"} class="hover:text-[#141414]">
        <%= List.first(@product.categories).name %>
      </.link>
    <% end %>
    <span>/</span>
    <span class="text-[#141414]"><%= @product.name %></span>
  </nav>

  <%!-- ── HERO — Gallery + Buy Panel ─────────────────────���───────────── --%>
  <section class="pb-10">
    <div class="grid grid-cols-12 gap-6 md:gap-10">

      <%!-- LEFT: Gallery --%>
      <div class="col-span-12 md:col-span-6">
        <%!-- Main image --%>
        <div class="relative aspect-square bg-white rounded-2xl border border-neutral-200/70 overflow-hidden ring-1 ring-black/5">
          <%= for {image, idx} <- Enum.with_index(if(Enum.empty?(@product.images), do: [@product.image], else: @product.images)) do %>
            <div
              class="absolute inset-0 transition-transform duration-500 ease-in-out"
              style={"transform: translateX(#{(idx - @current_image_index) * 100}%);"}
            >
              <img
                src={BlocksterV2.ImageKit.w800_h800(image)}
                alt={"#{@product.name} - Image #{idx + 1}"}
                class="w-full h-full object-cover"
                fetchpriority={if(idx == 0, do: "high", else: "low")}
                loading={if(idx == 0, do: "eager", else: "lazy")}
              />
            </div>
          <% end %>

          <%!-- Navigation arrows --%>
          <%= if length(@product.images) > 1 do %>
            <button
              phx-click="prev_image"
              class="absolute left-4 top-1/2 -translate-y-1/2 w-12 h-12 rounded-full bg-white/90 hover:bg-white shadow-lg flex items-center justify-center transition-all hover:scale-110 cursor-pointer"
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none">
                <path d="M15 18L9 12L15 6" stroke="#141414" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </button>
            <button
              phx-click="next_image"
              class="absolute right-4 top-1/2 -translate-y-1/2 w-12 h-12 rounded-full bg-white/90 hover:bg-white shadow-lg flex items-center justify-center transition-all hover:scale-110 cursor-pointer"
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none">
                <path d="M9 18L15 12L9 6" stroke="#141414" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </button>
          <% end %>
        </div>

        <%!-- Thumbnail strip --%>
        <%= if length(@product.images) > 1 do %>
          <div class="mt-3 grid grid-cols-4 gap-3">
            <%= for {_image, idx} <- Enum.with_index(@product.images) do %>
              <button
                phx-click="select_image"
                phx-value-index={idx}
                class={[
                  "aspect-square bg-white rounded-xl overflow-hidden cursor-pointer transition-colors",
                  if(idx == @current_image_index,
                    do: "border-2 border-[#141414]",
                    else: "border border-neutral-200 hover:border-[#141414]"
                  )
                ]}
              >
                <img
                  src={BlocksterV2.ImageKit.w128_h128(Enum.at(@product.images, idx))}
                  alt={"Thumbnail #{idx + 1}"}
                  class="w-full h-full object-cover"
                  loading="lazy"
                />
              </button>
            <% end %>
          </div>
        <% end %>
      </div>

      <%!-- RIGHT: Buy panel --%>
      <div class="col-span-12 md:col-span-6">
        <div class="sticky top-[100px] self-start">

          <%!-- Collection eyebrow --%>
          <%= if @product.collection_name do %>
            <div class="text-[10px] font-bold uppercase tracking-[0.16em] text-neutral-500 mb-2">
              <%= @product.collection_name %>
            </div>
          <% end %>

          <%!-- Title --%>
          <div class="flex items-center gap-3 mb-4 flex-wrap">
            <h1 class="font-bold tracking-[-0.022em] leading-[1.0] text-[36px] md:text-[44px]">
              <%= @product.name %>
            </h1>
            <%!-- Admin edit button --%>
            <%= if @current_user && @current_user.is_admin do %>
              <.link
                navigate={~p"/admin/products/#{@product.id}/edit"}
                class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-neutral-100 text-neutral-700 text-sm font-medium hover:bg-neutral-200 transition-colors cursor-pointer"
              >
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/>
                  <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/>
                </svg>
                Edit
              </.link>
            <% end %>
          </div>

          <%!-- Hub + categories + tags badges --%>
          <div class="flex flex-wrap items-center gap-2 mb-5">
            <%!-- Hub badge (black pill with gradient dot) --%>
            <%= if @product.hub_name do %>
              <.link
                navigate={~p"/hub/#{@product.hub_slug}"}
                class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full bg-[#0a0a0a] text-white text-[12px] font-bold hover:bg-[#1a1a22] transition-colors cursor-pointer"
              >
                <%= if @hub_color_primary do %>
                  <div class="w-4 h-4 rounded-full" style={"background: linear-gradient(135deg, #{@hub_color_primary}, #{@hub_color_secondary || @hub_color_primary});"}></div>
                <% else %>
                  <%= if @product.hub_logo_url do %>
                    <img src={@product.hub_logo_url} alt={@product.hub_name} class="w-4 h-4 rounded-full object-cover" />
                  <% end %>
                <% end %>
                <%= @product.hub_name %>
              </.link>
            <% end %>

            <%!-- Artist badge --%>
            <%= if @product.artist_name do %>
              <%= if @product.artist_slug do %>
                <.link
                  navigate={~p"/shop?artist=#{@product.artist_slug}"}
                  class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full bg-purple-100 text-purple-700 text-[12px] font-bold hover:bg-purple-200 transition-colors cursor-pointer"
                >
                  <%= if @product.artist_image do %>
                    <img src={@product.artist_image} alt={@product.artist_name} class="w-4 h-4 rounded-full object-cover" />
                  <% end %>
                  <%= @product.artist_name %>
                </.link>
              <% else %>
                <span class="inline-flex items-center gap-1 px-3 py-1 rounded-full bg-purple-100 text-purple-700 text-[12px] font-bold">
                  <%= @product.artist_name %>
                </span>
              <% end %>
            <% end %>

            <%!-- Category badges --%>
            <%= for category <- @product.categories do %>
              <.link
                navigate={~p"/shop?category=#{category.slug}"}
                class="inline-flex items-center gap-1 px-3 py-1 rounded-full bg-neutral-100 text-neutral-700 text-[12px] font-bold hover:bg-neutral-200 transition-colors cursor-pointer"
              >
                <%= category.name %>
              </.link>
            <% end %>

            <%!-- Product type fallback --%>
            <%= if Enum.empty?(@product.categories) && @product.product_type do %>
              <span class="inline-flex items-center gap-1 px-3 py-1 rounded-full bg-neutral-100 text-neutral-700 text-[12px] font-bold">
                <%= @product.product_type %>
              </span>
            <% end %>

            <%!-- Product tags (many-to-many) --%>
            <%= for tag <- @product.product_tags do %>
              <.link
                navigate={~p"/shop?tag=#{tag.slug}"}
                class="inline-flex items-center px-2.5 py-0.5 rounded-full bg-[#CAFC00]/20 text-[#141414] text-[10px] font-bold hover:bg-[#CAFC00]/30 transition-colors cursor-pointer"
              >
                #<%= tag.name %>
              </.link>
            <% end %>

            <%!-- Simple string tags --%>
            <%= for tag <- @product.tags do %>
              <span class="inline-flex items-center px-2.5 py-0.5 rounded-full bg-neutral-100 text-neutral-600 text-[10px] font-bold">
                #<%= tag %>
              </span>
            <% end %>
          </div>

          <%!-- Price block --%>
          <%
            total_price = @product.price * @quantity
            discount_amount_top = @tokens_to_redeem * @token_value_usd
            discounted_price_top = max(total_price - discount_amount_top, 0)
            discount_percent_top = if total_price > 0, do: round(discount_amount_top / total_price * 100), else: 0
            has_discount = @tokens_to_redeem > 0
          %>
          <div class="flex flex-wrap items-baseline gap-3 mb-2">
            <%= if has_discount do %>
              <span class="font-mono font-bold text-[40px] text-[#141414] leading-none tracking-tight">
                $<%= :erlang.float_to_binary(discounted_price_top, decimals: 2) %>
              </span>
              <span class="text-[18px] font-mono text-neutral-400 line-through">
                $<%= :erlang.float_to_binary(total_price, decimals: 2) %>
              </span>
              <span class="px-2 py-1 rounded-full bg-[#22C55E]/10 text-[#15803d] border border-[#22C55E]/25 text-[11px] font-bold">
                <%= discount_percent_top %>% OFF
              </span>
            <% else %>
              <span class="font-mono font-bold text-[40px] text-[#141414] leading-none tracking-tight">
                $<%= :erlang.float_to_binary(total_price, decimals: 2) %>
              </span>
            <% end %>
          </div>
          <button
            phx-click="toggle_discount_breakdown"
            class="text-[12px] text-neutral-500 hover:text-[#141414] font-medium underline mb-6 cursor-pointer"
          >
            <%= if @show_discount_breakdown, do: "Hide discount breakdown", else: "Discount breakdown" %>
          </button>

          <%!-- BUX Redemption card --%>
          <%= if @show_discount_breakdown do %>
            <%
              total_price_bd = @product.price * @quantity
              discount_amount = @tokens_to_redeem * @token_value_usd
              discounted_price = max(total_price_bd - discount_amount, 0)
              discount_percent = if total_price_bd > 0, do: round(discount_amount / total_price_bd * 100), else: 0
              effective_max = min(@max_bux_tokens, @user_bux_balance)
            %>
            <div class="bg-neutral-50 border border-neutral-200 rounded-2xl p-5 mb-6">
              <div class="flex items-center gap-2 mb-4">
                <img src="https://ik.imagekit.io/blockster/blockster-icon.png" alt="" class="w-6 h-6 rounded-full" />
                <span class="text-[13px] font-bold text-[#141414]">Redeem BUX tokens</span>
              </div>

              <%!-- Balance --%>
              <div class="flex items-center justify-between mb-4 text-[12px]">
                <span class="text-neutral-500 font-medium">Your BUX balance</span>
                <span class="font-mono font-bold text-[#141414]"><%= Number.Delimit.number_to_delimited(@user_bux_balance, precision: 2) %> BUX</span>
              </div>

              <%!-- Input --%>
              <div class="mb-3">
                <div class="flex items-center justify-between mb-2">
                  <label class="text-[11px] text-neutral-500 font-medium">BUX to redeem</label>
                  <span class="text-[10px] font-mono text-neutral-400">
                    Max: <%= Number.Delimit.number_to_delimited(effective_max, precision: 0) %><%= if @product.bux_max_discount > 0, do: " (#{@product.bux_max_discount}% off)", else: "" %>
                  </span>
                </div>
                <div class="flex items-center gap-2">
                  <form phx-change="update_tokens" class="flex-1 flex items-center gap-2">
                    <input
                      type="number"
                      min="0"
                      max={:erlang.float_to_binary(effective_max / 1, decimals: 2)}
                      step="0.1"
                      value={:erlang.float_to_binary(@tokens_to_redeem / 1, decimals: 2)}
                      phx-debounce="300"
                      name="tokens"
                      id="token-input"
                      phx-hook="TokenInput"
                      data-max={:erlang.float_to_binary(effective_max / 1, decimals: 2)}
                      class="flex-1 bg-white border border-neutral-200 rounded-xl px-3 py-2.5 text-[16px] font-mono font-bold text-[#141414] focus:outline-none focus:border-[#141414]"
                    />
                    <button
                      type="button"
                      phx-click="use_max_tokens"
                      class="bg-[#0a0a0a] text-white px-4 py-2.5 rounded-xl text-[12px] font-bold hover:bg-[#1a1a22] transition-colors cursor-pointer"
                    >
                      Max
                    </button>
                  </form>
                </div>
              </div>

              <%!-- Calculation --%>
              <div class="pt-4 border-t border-neutral-200 space-y-2 text-[12px]">
                <div class="flex items-center justify-between">
                  <span class="text-neutral-500 font-medium">Token discount</span>
                  <span class="font-mono font-bold text-[#15803d]">−$<%= :erlang.float_to_binary(discount_amount, decimals: 2) %> (<%= discount_percent %>% off)</span>
                </div>
                <div class="flex items-center justify-between">
                  <span class="text-neutral-500 font-medium">You pay</span>
                  <span class="font-mono font-bold text-[18px] text-[#141414]">$<%= :erlang.float_to_binary(discounted_price, decimals: 2) %></span>
                </div>
              </div>

              <div class="mt-3 text-[10px] text-neutral-400 font-mono">1 BUX = $0.01 discount</div>
            </div>
          <% end %>

          <%!-- Description --%>
          <div class="mb-6">
            <h3 class="text-[14px] font-bold text-[#141414] mb-2">Description</h3>
            <div class="text-[13px] text-neutral-600 font-medium leading-relaxed prose prose-sm max-w-none [&_a]:text-blue-500 [&_a]:no-underline [&_a:hover]:underline">
              <%= raw(@product.description) %>
            </div>
          </div>

          <%!-- Size selection --%>
          <%= if @product_config && @product_config.has_sizes && Enum.any?(@display_sizes) do %>
            <div class="mb-6">
              <%= case @product_config.size_type do %>
                <% "clothing" -> %>
                  <h3 class="text-[14px] font-bold text-[#141414] mb-3">Select size</h3>
                  <div class="flex flex-wrap gap-2">
                    <%= for size <- @display_sizes do %>
                      <button
                        phx-click="select_size"
                        phx-value-size={size}
                        class={[
                          "px-3.5 py-2 rounded-xl border-2 font-semibold text-[12px] transition-all cursor-pointer",
                          if(@selected_size == size,
                            do: "bg-[#0a0a0a] text-white border-[#0a0a0a]",
                            else: "bg-white text-[#6B7280] border-[#e5e5e2] hover:border-[#141414] hover:text-[#141414]"
                          )
                        ]}
                      >
                        <%= size %>
                      </button>
                    <% end %>
                  </div>

                <% "mens_shoes" -> %>
                  <div class="text-[14px] font-bold text-[#141414] mb-3">Men's shoe size</div>
                  <div class="grid grid-cols-4 sm:grid-cols-5 gap-2">
                    <%= for size <- @display_sizes do %>
                      <button
                        phx-click="select_size"
                        phx-value-size={size}
                        class={[
                          "px-2 py-2.5 rounded-xl border-2 font-semibold text-[12px] text-center transition-all cursor-pointer",
                          if(@selected_size == size,
                            do: "bg-[#0a0a0a] text-white border-[#0a0a0a]",
                            else: "bg-white text-[#6B7280] border-[#e5e5e2] hover:border-[#141414] hover:text-[#141414]"
                          )
                        ]}
                      >
                        <%= size %>
                      </button>
                    <% end %>
                  </div>

                <% "womens_shoes" -> %>
                  <div class="text-[14px] font-bold text-[#141414] mb-3">Women's shoe size</div>
                  <div class="grid grid-cols-4 sm:grid-cols-5 gap-2">
                    <%= for size <- @display_sizes do %>
                      <button
                        phx-click="select_size"
                        phx-value-size={size}
                        class={[
                          "px-2 py-2.5 rounded-xl border-2 font-semibold text-[12px] text-center transition-all cursor-pointer",
                          if(@selected_size == size,
                            do: "bg-[#0a0a0a] text-white border-[#0a0a0a]",
                            else: "bg-white text-[#6B7280] border-[#e5e5e2] hover:border-[#141414] hover:text-[#141414]"
                          )
                        ]}
                      >
                        <%= size %>
                      </button>
                    <% end %>
                  </div>

                <% "unisex_shoes" -> %>
                  <%!-- Men's / Women's toggle --%>
                  <div class="flex gap-2 mb-3">
                    <button
                      phx-click="set_shoe_gender"
                      phx-value-gender="mens"
                      class={[
                        "px-4 py-2 rounded-xl font-bold text-[12px] transition-all cursor-pointer",
                        if(@shoe_gender == "mens",
                          do: "bg-[#0a0a0a] text-white",
                          else: "bg-neutral-100 text-neutral-500 hover:bg-neutral-200"
                        )
                      ]}
                    >
                      Men's
                    </button>
                    <button
                      phx-click="set_shoe_gender"
                      phx-value-gender="womens"
                      class={[
                        "px-4 py-2 rounded-xl font-bold text-[12px] transition-all cursor-pointer",
                        if(@shoe_gender == "womens",
                          do: "bg-[#0a0a0a] text-white",
                          else: "bg-neutral-100 text-neutral-500 hover:bg-neutral-200"
                        )
                      ]}
                    >
                      Women's
                    </button>
                  </div>
                  <div class="text-[14px] font-bold text-[#141414] mb-3">
                    <%= if @shoe_gender == "womens", do: "Women's", else: "Men's" %> shoe size
                  </div>
                  <div class="grid grid-cols-4 sm:grid-cols-5 gap-2">
                    <%= for size <- @display_sizes do %>
                      <button
                        phx-click="select_size"
                        phx-value-size={size}
                        class={[
                          "px-2 py-2.5 rounded-xl border-2 font-semibold text-[12px] text-center transition-all cursor-pointer",
                          if(@selected_size == size,
                            do: "bg-[#0a0a0a] text-white border-[#0a0a0a]",
                            else: "bg-white text-[#6B7280] border-[#e5e5e2] hover:border-[#141414] hover:text-[#141414]"
                          )
                        ]}
                      >
                        <%= size %>
                      </button>
                    <% end %>
                  </div>

                <% "one_size" -> %>
                  <div class="text-[12px] font-medium text-neutral-500">One Size</div>

                <% _ -> %>
                  <h3 class="text-[14px] font-bold text-[#141414] mb-3">Select size</h3>
                  <div class="flex flex-wrap gap-2">
                    <%= for size <- @display_sizes do %>
                      <button
                        phx-click="select_size"
                        phx-value-size={size}
                        class={[
                          "px-3.5 py-2 rounded-xl border-2 font-semibold text-[12px] transition-all cursor-pointer",
                          if(@selected_size == size,
                            do: "bg-[#0a0a0a] text-white border-[#0a0a0a]",
                            else: "bg-white text-[#6B7280] border-[#e5e5e2] hover:border-[#141414] hover:text-[#141414]"
                          )
                        ]}
                      >
                        <%= size %>
                      </button>
                    <% end %>
                  </div>
              <% end %>
            </div>
          <% else %>
            <%!-- Legacy fallback: show sizes if product has them but no config --%>
            <%= if is_nil(@product_config) && Enum.any?(@product.sizes) do %>
              <div class="mb-6">
                <h3 class="text-[14px] font-bold text-[#141414] mb-3">Select size</h3>
                <div class="flex flex-wrap gap-2">
                  <%= for size <- @product.sizes do %>
                    <button
                      phx-click="select_size"
                      phx-value-size={size}
                      class={[
                        "px-3.5 py-2 rounded-xl border-2 font-semibold text-[12px] transition-all cursor-pointer",
                        if(@selected_size == size,
                          do: "bg-[#0a0a0a] text-white border-[#0a0a0a]",
                          else: "bg-white text-[#6B7280] border-[#e5e5e2] hover:border-[#141414] hover:text-[#141414]"
                        )
                      ]}
                    >
                      <%= size %>
                    </button>
                  <% end %>
                </div>
              </div>
            <% end %>
          <% end %>

          <%!-- Color selection --%>
          <%= if (@product_config && @product_config.has_colors && Enum.any?(@product.colors)) || (is_nil(@product_config) && Enum.any?(@product.colors)) do %>
            <div class="mb-6">
              <h3 class="text-[14px] font-bold text-[#141414] mb-3">
                Select color<%= if @selected_color do %> · <span class="text-neutral-500 font-medium font-normal"><%= @selected_color %></span><% end %>
              </h3>
              <div class="flex items-center gap-3">
                <%= for color <- @product.colors do %>
                  <% hex_code = Map.get(@color_hex_map, color, "#808080") %>
                  <button
                    phx-click="select_color"
                    phx-value-color={color}
                    class={[
                      "w-9 h-9 rounded-full cursor-pointer transition-shadow",
                      if(hex_code == "#FFFFFF", do: "border-2 border-white shadow-[0_0_0_1px_#e5e5e2]", else: "border-2 border-white shadow-[0_0_0_1px_#e5e5e2]"),
                      if(@selected_color == color, do: "!shadow-[0_0_0_2px_#141414]", else: "hover:shadow-[0_0_0_1px_#141414]")
                    ]}
                    style={"background-color: #{hex_code};"}
                    title={color}
                  />
                <% end %>
              </div>
            </div>
          <% end %>

          <%!-- Quantity --%>
          <div class="mb-6">
            <h3 class="text-[14px] font-bold text-[#141414] mb-3">Quantity</h3>
            <div class="inline-flex items-center bg-white border border-neutral-200 rounded-full overflow-hidden">
              <button
                phx-click="decrement_quantity"
                class="px-4 py-2 text-[14px] font-medium text-neutral-500 hover:text-[#141414] hover:bg-neutral-50 cursor-pointer disabled:opacity-50 disabled:cursor-not-allowed"
                disabled={@quantity <= 1}
              >
                −
              </button>
              <span class="px-3 font-mono font-bold text-[14px] text-[#141414] min-w-[36px] text-center">
                <%= @quantity %>
              </span>
              <button
                phx-click="increment_quantity"
                class="px-4 py-2 text-[14px] font-medium text-neutral-500 hover:text-[#141414] hover:bg-neutral-50 cursor-pointer"
              >
                +
              </button>
            </div>
          </div>

          <%!-- CTAs --%>
          <div class="space-y-2 mb-5">
            <%= if @product_config && @product_config.checkout_enabled == false do %>
              <button
                class="w-full inline-flex items-center justify-center gap-2 bg-neutral-300 text-neutral-500 px-5 py-3.5 rounded-full text-[14px] font-bold cursor-not-allowed"
                disabled
              >
                Coming Soon
              </button>
            <% else %>
              <button
                phx-click="add_to_cart"
                class="w-full inline-flex items-center justify-center gap-2 bg-[#0a0a0a] text-white px-5 py-3.5 rounded-full text-[14px] font-bold hover:bg-[#1a1a22] transition-colors cursor-pointer"
              >
                Add to cart · $<%= :erlang.float_to_binary(if(@tokens_to_redeem > 0, do: max(@product.price * @quantity - @tokens_to_redeem * @token_value_usd, 0), else: @product.price * @quantity), decimals: 2) %>
                <svg class="w-3.5 h-3.5" viewBox="0 0 20 20" fill="none"><path d="M3 10h12m0 0l-4-4m4 4l-4 4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </button>
              <button class="w-full text-center text-[12px] text-neutral-500 hover:text-[#141414] font-medium py-2 underline cursor-pointer">
                Buy it now
              </button>
            <% end %>
            <%= if @added_to_cart do %>
              <.link
                navigate={~p"/cart"}
                class="block w-full text-center bg-[#141414] text-white font-bold text-[14px] py-3.5 px-5 rounded-full transition-all hover:bg-[#1a1a22] cursor-pointer"
              >
                Go to checkout
              </.link>
            <% end %>
          </div>

          <%!-- Reassurance grid --%>
          <div class="grid grid-cols-3 gap-3 text-center">
            <div class="bg-white rounded-xl border border-neutral-200/70 p-3">
              <svg class="w-4 h-4 mx-auto mb-1 text-neutral-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="3" width="15" height="13" rx="1"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
              <div class="text-[10px] text-neutral-500 font-medium leading-tight">Ships in 3-5 days</div>
            </div>
            <div class="bg-white rounded-xl border border-neutral-200/70 p-3">
              <svg class="w-4 h-4 mx-auto mb-1 text-neutral-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
              <div class="text-[10px] text-neutral-500 font-medium leading-tight">Sustainably sourced</div>
            </div>
            <div class="bg-white rounded-xl border border-neutral-200/70 p-3">
              <svg class="w-4 h-4 mx-auto mb-1 text-neutral-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 11 12 14 22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/></svg>
              <div class="text-[10px] text-neutral-500 font-medium leading-tight">30-day returns</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <%!-- ── Related Products ──────────────────────���────────────────────── --%>
  <%= if @product.hub_name && Enum.any?(@related_products) do %>
    <section class="py-12 border-t border-neutral-200/70">
      <div class="flex items-baseline justify-between mb-6 flex-wrap gap-3">
        <div>
          <div class="text-[10px] font-bold tracking-[0.16em] uppercase text-[#9CA3AF] mb-1">More from the <%= @product.hub_name %> community</div>
          <h2 class="font-bold tracking-[-0.018em] text-[28px] md:text-[34px]">You may also like</h2>
        </div>
        <.link navigate={~p"/shop?hub=#{@product.hub_slug}"} class="text-[13px] font-medium text-neutral-600 hover:text-neutral-900 transition-colors">
          All <%= @product.hub_name %> →
        </.link>
      </div>

      <div class="grid grid-cols-2 md:grid-cols-4 gap-5">
        <%= for rp <- @related_products do %>
          <.link
            navigate={~p"/shop/#{rp.slug}"}
            class="group block bg-white rounded-2xl border border-neutral-200/70 overflow-hidden flex flex-col transition-transform duration-200 hover:-translate-y-0.5 hover:shadow-lg hover:border-black/10"
          >
            <div class="aspect-square bg-neutral-100 overflow-hidden">
              <img src={BlocksterV2.ImageKit.w500_h500(rp.image)} alt={rp.name} class="w-full h-full object-cover" loading="lazy" />
            </div>
            <div class="p-4 text-center">
              <h3 class="font-bold text-[14px] text-[#141414] leading-tight mb-2 line-clamp-2"><%= rp.name %></h3>
              <div class="flex flex-col items-center mb-3">
                <%= if rp.total_max_discount > 0 do %>
                  <span class="text-[10px] text-neutral-400 line-through font-mono">$<%= :erlang.float_to_binary(rp.price, decimals: 2) %></span>
                  <span class="font-mono font-bold text-[18px] text-[#141414]">$<%= :erlang.float_to_binary(rp.max_discounted_price, decimals: 2) %></span>
                  <span class="text-[9px] text-neutral-500 font-medium">with BUX tokens</span>
                <% else %>
                  <span class="font-mono font-bold text-[18px] text-[#141414]">$<%= :erlang.float_to_binary(rp.price, decimals: 2) %></span>
                <% end %>
              </div>
              <div class="w-full py-1.5 bg-[#0a0a0a] text-white text-[11px] font-bold rounded-full">Buy Now</div>
            </div>
          </.link>
        <% end %>
      </div>
    </section>
  <% end %>

</main>

<BlocksterV2Web.DesignSystem.footer />
