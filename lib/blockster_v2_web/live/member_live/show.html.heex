<%!-- Member page · owner profile or public member view --%>
<BlocksterV2Web.DesignSystem.header
  current_user={@current_user}
  active={if @is_own_profile, do: "profile", else: "member"}
  bux_balance={Map.get(assigns, :bux_balance, 0)}
  token_balances={Map.get(assigns, :token_balances, %{})}
  cart_item_count={Map.get(assigns, :cart_item_count, 0)}
  unread_notification_count={Map.get(assigns, :unread_notification_count, 0)}
  notification_dropdown_open={Map.get(assigns, :notification_dropdown_open, false)}
  recent_notifications={Map.get(assigns, :recent_notifications, [])}
  search_query={Map.get(assigns, :search_query, "")}
  search_results={Map.get(assigns, :search_results, [])}
  show_search_results={Map.get(assigns, :show_search_results, false)}
  show_search_modal={Map.get(assigns, :show_search_modal, false)}
  connecting={Map.get(assigns, :connecting, false)}
  show_why_earn_bux={true}
/>

<%= if @is_own_profile do %>
<%!-- ═══════════════════════════════════════════════
     OWNER PROFILE VIEW (existing profile redesign)
═══════════════════════════════════════════════ --%>
<main class="max-w-[1280px] mx-auto px-6">
  <%!-- ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
       PROFILE HERO — Identity + Quick Actions
  ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ --%>
  <section class="ds-profile-hero pt-12 pb-10">
    <div class="grid grid-cols-12 gap-8 items-start">
      <%!-- Identity (left) --%>
      <div class="col-span-12 md:col-span-7">
        <div class="flex items-start gap-5">
          <BlocksterV2Web.DesignSystem.profile_avatar
            initials={user_initials(@member)}
            size="xl"
          />
          <div class="flex-1 min-w-0">
            <div class="flex items-center gap-2 mb-2">
              <BlocksterV2Web.DesignSystem.eyebrow>Your profile</BlocksterV2Web.DesignSystem.eyebrow>
              <span class="inline-flex items-center gap-1 bg-[#22C55E]/10 text-[#15803d] border border-[#22C55E]/25 px-2 py-0.5 rounded-full text-[10px] font-bold uppercase tracking-wider">
                <span class="w-1.5 h-1.5 rounded-full bg-[#22C55E] animate-[pulse-dot_1.6s_cubic-bezier(0.4,0,0.6,1)_infinite]"></span>
                Active
              </span>
            </div>
            <h1 class="font-bold text-[44px] md:text-[52px] text-[#141414] tracking-[-0.022em] leading-[0.96] mb-2">
              <%= @member.username || "Member" %>
            </h1>
            <div class="flex items-center gap-2 text-[13px] text-neutral-500">
              <span>@<%= @member.slug || @member.username || "user" %></span>
              <span class="text-neutral-300">&middot;</span>
              <span>blockster.com/member/<%= @member.slug || @member.wallet_address %></span>
            </div>

            <%!-- Wallet + member since --%>
            <div class="mt-5 flex flex-wrap items-center gap-x-5 gap-y-2 text-[12px]">
              <%= if @member.wallet_address do %>
                <div class="flex items-center gap-2 text-neutral-600">
                  <svg class="w-3.5 h-3.5 text-neutral-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <rect x="2" y="6" width="20" height="14" rx="2"/><path d="M22 10h-4a2 2 0 100 4h4"/>
                  </svg>
                  <span class="font-mono text-[12px] text-neutral-700"><%= truncate_wallet(@member.wallet_address) %></span>
                  <button
                    type="button"
                    id={"copy-wallet-hero-#{@member.id}"}
                    phx-hook="CopyToClipboard"
                    data-copy-text={@member.wallet_address}
                    class="text-neutral-400 hover:text-[#141414] transition-colors cursor-pointer"
                    title="Copy"
                  >
                    <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/>
                    </svg>
                  </button>
                  <a
                    href={"https://solscan.io/account/#{@member.wallet_address}?cluster=devnet"}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="text-[11px] text-neutral-400 hover:text-[#141414] transition-colors underline"
                  >Solscan &#8599;</a>
                </div>
              <% end %>
              <div class="flex items-center gap-2 text-neutral-600">
                <svg class="w-3.5 h-3.5 text-neutral-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/>
                </svg>
                <span>Member since <%= Calendar.strftime(@member.inserted_at, "%B %Y") %></span>
              </div>
            </div>
          </div>
        </div>
      </div>

      <%!-- Quick actions (right) --%>
      <div class="col-span-12 md:col-span-5">
        <div class="flex flex-col gap-3 md:items-end">
          <div class="flex flex-wrap gap-2 md:justify-end">
            <a
              href={~p"/api/auth/session"}
              method="delete"
              data-confirm="Are you sure you want to log out?"
              class="inline-flex items-center gap-2 bg-white border border-neutral-200 text-[#141414] px-3 py-2.5 rounded-full text-[12px] hover:border-[#141414] transition-colors cursor-pointer"
              title="Logout"
            >
              <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
            </a>
          </div>
          <%!-- Verification status mini pills --%>
          <div class="flex flex-wrap gap-2 md:justify-end mt-1">
            <%!-- X — clickable when not connected --%>
            <%= if @x_connection do %>
              <div class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full bg-white border border-neutral-200">
                <svg class="w-3 h-3 text-[#22C55E]" viewBox="0 0 24 24" fill="currentColor"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41L9 16.17z"/></svg>
                <span class="text-[10px] font-bold uppercase tracking-wider text-neutral-700">X</span>
              </div>
            <% else %>
              <a href={~p"/auth/x"} class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full bg-[#facc15]/15 border border-[#facc15]/40 cursor-pointer hover:border-[#a16207] transition-colors">
                <svg class="w-3 h-3 text-[#a16207]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
                <span class="text-[10px] font-bold uppercase tracking-wider text-[#a16207]">X</span>
              </a>
            <% end %>
            <%!-- Phone — clickable when not verified --%>
            <%= if @member.phone_verified do %>
              <div class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full bg-white border border-neutral-200">
                <svg class="w-3 h-3 text-[#22C55E]" viewBox="0 0 24 24" fill="currentColor"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41L9 16.17z"/></svg>
                <span class="text-[10px] font-bold uppercase tracking-wider text-neutral-700">Phone</span>
              </div>
            <% else %>
              <button phx-click="open_phone_verification" class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full bg-[#facc15]/15 border border-[#facc15]/40 cursor-pointer hover:border-[#a16207] transition-colors">
                <svg class="w-3 h-3 text-[#a16207]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
                <span class="text-[10px] font-bold uppercase tracking-wider text-[#a16207]">Phone</span>
              </button>
            <% end %>
            <%!-- SOL (not clickable — user needs to fund externally) --%>
            <% sol_bal = BlocksterV2.EngagementTracker.get_user_sol_balance(@member.id) %>
            <div class={[
              "inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full",
              if(sol_bal > 0, do: "bg-white border border-neutral-200", else: "bg-[#facc15]/15 border border-[#facc15]/40")
            ]}>
              <%= if sol_bal > 0 do %>
                <svg class="w-3 h-3 text-[#22C55E]" viewBox="0 0 24 24" fill="currentColor"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41L9 16.17z"/></svg>
              <% else %>
                <svg class="w-3 h-3 text-[#a16207]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
              <% end %>
              <span class={["text-[10px] font-bold uppercase tracking-wider", if(sol_bal > 0, do: "text-neutral-700", else: "text-[#a16207]")]}>SOL</span>
            </div>
            <%!-- Email — clickable when not verified --%>
            <%= if @member.email_verified do %>
              <div class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full bg-white border border-neutral-200">
                <svg class="w-3 h-3 text-[#22C55E]" viewBox="0 0 24 24" fill="currentColor"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41L9 16.17z"/></svg>
                <span class="text-[10px] font-bold uppercase tracking-wider text-neutral-700">Email</span>
              </div>
            <% else %>
              <button phx-click="open_email_verification" class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full bg-[#facc15]/15 border border-[#facc15]/40 cursor-pointer hover:border-[#a16207] transition-colors">
                <svg class="w-3 h-3 text-[#a16207]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
                <span class="text-[10px] font-bold uppercase tracking-wider text-[#a16207]">Email</span>
              </button>
            <% end %>
          </div>
        </div>
      </div>
    </div>

    <%!-- New user claim success banner --%>
    <%= if @is_new_user && length(Map.get(assigns, :claimed_rewards, [])) > 0 do %>
      <div class="mt-6 bg-[#22C55E]/10 border border-[#22C55E]/25 rounded-2xl p-5 flex items-center gap-4 flex-wrap" phx-hook="ClaimCleanup" id="claim-success-banner">
        <div class="w-10 h-10 rounded-xl bg-[#22C55E]/15 grid place-items-center shrink-0">
          <svg class="w-5 h-5 text-[#15803d]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
        </div>
        <div class="flex-1 min-w-0">
          <div class="font-bold text-[14px] text-[#141414]">
            Successfully claimed <%= Float.round(@total_claimed, 2) %> BUX from <%= @claim_type_text %>!
          </div>
        </div>
      </div>
    <% end %>

    <%!-- Three stat cards --%>
    <% bux_balance = Map.get(@token_balances || %{}, "BUX", 0) %>
    <% sol_balance = BlocksterV2.EngagementTracker.get_user_sol_balance(@member.id) %>
    <div class="mt-10 grid grid-cols-1 md:grid-cols-3 gap-4">
      <%!-- BUX Balance --%>
      <BlocksterV2Web.DesignSystem.stat_card label="BUX Balance" value={format_number(bux_balance)} unit="BUX">
        <:icon>
          <img src="https://ik.imagekit.io/blockster/blockster-icon.png" alt="" class="w-5 h-5 rounded-full" />
        </:icon>
        <:footer>
          <span class="text-neutral-500">Use BUX to enter airdrops &amp; play games</span>
        </:footer>
      </BlocksterV2Web.DesignSystem.stat_card>

      <%!-- BUX Multiplier --%>
      <BlocksterV2Web.DesignSystem.stat_card label="BUX Multiplier" value={format_multiplier(@overall_multiplier)} unit="×" icon_bg="#0a0a0a" class="relative overflow-hidden">
        <:icon>
          <svg class="w-5 h-5 text-[#CAFC00]" viewBox="0 0 24 24" fill="currentColor"><path d="M13 2L3 14h7l-1 8 10-12h-7l1-8z"/></svg>
        </:icon>
        <:footer>
          <span class="text-neutral-500">of 200&times; max possible</span>
          <%= unless @member.email_verified do %>
            <span class="font-mono font-bold text-[#a16207]">Verify email &rarr;</span>
          <% end %>
        </:footer>
      </BlocksterV2Web.DesignSystem.stat_card>

      <%!-- SOL Balance --%>
      <div class="ds-stat-card bg-white rounded-2xl border border-neutral-200/70 p-6 shadow-[0_1px_3px_rgba(0,0,0,0.04)]">
        <div class="flex items-start justify-between mb-4">
          <BlocksterV2Web.DesignSystem.eyebrow>SOL Balance</BlocksterV2Web.DesignSystem.eyebrow>
          <div class="w-9 h-9 rounded-xl grid place-items-center bg-black">
            <img src="https://ik.imagekit.io/blockster/solana-sol-logo.png" alt="SOL" class="w-5 h-5 rounded-full" />
          </div>
        </div>
        <div class="flex items-baseline gap-2 mb-1">
          <span class="font-mono font-bold text-[44px] text-[#141414] leading-none tracking-tight tabular-nums">
            <%= :erlang.float_to_binary(sol_balance * 1.0, decimals: 3) %>
          </span>
          <span class="text-[12px] text-neutral-500">SOL</span>
        </div>
        <div class="mt-4 pt-4 border-t border-neutral-100 flex items-center justify-between text-[10px]">
          <span class="text-neutral-500">SOL multiplier</span>
          <span class="font-mono font-bold text-[#141414]"><%= format_multiplier(@sol_multiplier) %>&times;</span>
        </div>
      </div>
    </div>
  </section>

  <%!-- ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
       EMAIL VERIFICATION BANNER (conditional)
  ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ --%>
  <%= unless @member.email_verified do %>
    <section class="ds-email-verify-banner pb-8">
      <div class="bg-gradient-to-r from-[#fef3c7] to-[#fef9c3] border border-[#facc15]/40 rounded-2xl p-5 flex items-center gap-4 flex-wrap">
        <div class="w-12 h-12 rounded-xl bg-white border border-[#facc15]/40 grid place-items-center shrink-0">
          <svg class="w-6 h-6 text-[#a16207]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
        </div>
        <div class="flex-1 min-w-0">
          <div class="flex items-center gap-2 mb-1">
            <span class="text-[10px] font-bold uppercase tracking-[0.14em] text-[#a16207]">One thing left</span>
          </div>
          <h3 class="font-bold text-[18px] text-[#141414] leading-tight">Verify your email to unlock <span class="text-[#a16207]">2&times; the BUX you're earning right now</span></h3>
          <p class="text-[12px] text-neutral-600 mt-1">Your current <%= format_multiplier(@overall_multiplier) %>&times; multiplier could be <%= format_multiplier(@overall_multiplier * 2) %>&times;. Add and verify a recovery email &mdash; takes 30 seconds.</p>
        </div>
        <button phx-click="open_email_verification" class="bg-[#0a0a0a] text-white px-5 py-2.5 rounded-full text-[12px] font-bold hover:bg-[#1a1a22] transition-colors shrink-0 cursor-pointer">Verify email &rarr;</button>
      </div>
    </section>
  <% end %>

  <%!-- ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
       PHONE VERIFICATION BANNER (conditional)
  ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ --%>
  <%= if !@member.phone_verified do %>
    <section class="ds-phone-verify-banner pb-8">
      <div class="bg-gradient-to-r from-[#fef3c7] to-[#fef9c3] border border-[#facc15]/40 rounded-2xl p-5 flex items-center gap-4 flex-wrap">
        <div class="w-12 h-12 rounded-xl bg-white border border-[#facc15]/40 grid place-items-center shrink-0">
          <svg class="w-6 h-6 text-[#a16207]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
        </div>
        <div class="flex-1 min-w-0">
          <h3 class="font-bold text-[18px] text-[#141414] leading-tight">Verify your phone to unlock <span class="text-[#a16207]">2&times; multiplier</span></h3>
          <p class="text-[12px] text-neutral-600 mt-1">Phone verification increases your BUX earning multiplier.</p>
        </div>
        <button phx-click="open_phone_verification" class="bg-[#0a0a0a] text-white px-5 py-2.5 rounded-full text-[12px] font-bold hover:bg-[#1a1a22] transition-colors shrink-0 cursor-pointer">Verify phone &rarr;</button>
      </div>
    </section>
  <% end %>

  <%!-- ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
       MULTIPLIER BREAKDOWN
  ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ --%>
  <section class="ds-multiplier-breakdown pb-12">
    <div class="bg-white rounded-2xl border border-neutral-200/70 shadow-[0_1px_3px_rgba(0,0,0,0.04)] overflow-hidden">
      <div class="px-6 py-5 border-b border-neutral-100 flex items-center justify-between flex-wrap gap-3">
        <div>
          <BlocksterV2Web.DesignSystem.eyebrow class="mb-1">How your multiplier works</BlocksterV2Web.DesignSystem.eyebrow>
          <h2 class="font-bold text-[22px] tracking-[-0.018em] text-[#141414]">Multiplier breakdown &middot; <span class="font-mono text-neutral-400">X &times; Phone &times; SOL &times; Email</span></h2>
        </div>
        <div class="flex items-baseline gap-2 bg-[#0a0a0a] text-white px-4 py-2 rounded-full">
          <span class="font-mono text-[10px] uppercase tracking-[0.12em] text-white/60">Total</span>
          <span class="font-mono font-bold text-[20px] leading-none text-[#CAFC00]"><%= format_multiplier(@overall_multiplier) %>&times;</span>
          <span class="font-mono text-[10px] uppercase tracking-[0.12em] text-white/60">/ 200&times; max</span>
        </div>
      </div>

      <%!-- 4 multiplier components --%>
      <div class="grid grid-cols-1 md:grid-cols-4 divide-y md:divide-y-0 md:divide-x divide-neutral-100">
        <%!-- X Multiplier --%>
        <div class={["p-5", unless(@x_connection, do: "bg-gradient-to-br from-[#fef9c3]/30 to-transparent")]}>
          <div class="flex items-center justify-between mb-3">
            <div class="flex items-center gap-2">
              <div class={["w-7 h-7 rounded-md grid place-items-center", if(@x_connection, do: "bg-[#0a0a0a]", else: "bg-neutral-200")]}>
                <svg class={["w-3.5 h-3.5", if(@x_connection, do: "text-white", else: "text-neutral-500")]} viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
              </div>
              <div>
                <div class="text-[12px] font-bold text-[#141414]">X Account</div>
                <div class={["text-[10px]", if(@x_connection, do: "text-neutral-500", else: "text-[#a16207]")]}>
                  <%= if @x_connection, do: "@#{@x_connection.username}", else: "Not connected" %>
                </div>
              </div>
            </div>
            <%= if @x_connection do %>
              <span class="text-[10px] font-bold text-[#22C55E] uppercase tracking-wider">Connected</span>
            <% else %>
              <a href={~p"/auth/x"} class="text-[10px] font-bold text-[#a16207] hover:text-[#7c2d12] uppercase tracking-wider transition-colors">Connect &rarr;</a>
            <% end %>
          </div>
          <div class={["font-mono font-bold text-[26px] leading-none mb-2", if(@x_connection, do: "text-[#141414]", else: "text-neutral-400")]}><%= format_multiplier(@x_multiplier) %>&times;</div>
          <% x_pct = min(Float.round(@x_multiplier / 10 * 100, 0), 100) %>
          <div class="h-1.5 bg-[#f3f4f6] rounded-full overflow-hidden mb-2"><div class={["h-full rounded-full", if(@x_connection, do: "bg-gradient-to-r from-[#7D00FF] to-[#4A00B8]", else: "bg-gradient-to-r from-[#d4d4d2] to-[#b4b4b2]")]} style={"width: #{x_pct}%"}></div></div>
          <div class="flex items-center justify-between text-[10px] text-neutral-500 font-mono">
            <span>1&times;</span>
            <span class="text-neutral-400">max 10&times;</span>
          </div>
        </div>

        <%!-- Phone Multiplier --%>
        <div class={["p-5", unless(@member.phone_verified, do: "bg-gradient-to-br from-[#fef9c3]/30 to-transparent")]}>
          <div class="flex items-center justify-between mb-3">
            <div class="flex items-center gap-2">
              <div class={["w-7 h-7 rounded-md grid place-items-center", if(@member.phone_verified, do: "bg-[#22C55E]", else: "bg-neutral-200")]}>
                <svg class={["w-3.5 h-3.5", if(@member.phone_verified, do: "text-white", else: "text-neutral-500")]} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
              </div>
              <div>
                <div class="text-[12px] font-bold text-[#141414]">Phone</div>
                <div class={["text-[10px]", if(@member.phone_verified, do: "text-neutral-500", else: "text-[#a16207]")]}>
                  <%= if @member.phone_verified, do: "Verified", else: "Not verified" %>
                </div>
              </div>
            </div>
            <%= if @member.phone_verified do %>
              <span class="text-[10px] font-bold text-[#22C55E] uppercase tracking-wider">Verified</span>
            <% else %>
              <button phx-click="open_phone_verification" class="text-[10px] font-bold text-[#a16207] hover:text-[#7c2d12] uppercase tracking-wider transition-colors cursor-pointer">Verify &rarr;</button>
            <% end %>
          </div>
          <div class={["font-mono font-bold text-[26px] leading-none mb-2", if(@member.phone_verified, do: "text-[#141414]", else: "text-neutral-400")]}><%= format_multiplier(@phone_multiplier) %>&times;</div>
          <% phone_pct = min(Float.round(@phone_multiplier / 2 * 100, 0), 100) %>
          <div class="h-1.5 bg-[#f3f4f6] rounded-full overflow-hidden mb-2"><div class={["h-full rounded-full", if(@member.phone_verified, do: "bg-gradient-to-r from-[#CAFC00] to-[#9ED600]", else: "bg-gradient-to-r from-[#d4d4d2] to-[#b4b4b2]")]} style={"width: #{phone_pct}%"}></div></div>
          <div class="flex items-center justify-between text-[10px] text-neutral-500 font-mono">
            <span>0.5&times;</span>
            <span class={if(@member.phone_verified, do: "text-neutral-400", else: "text-[#a16207]")}>max 2&times;<%= if @member.phone_verified, do: " ✓", else: " when verified" %></span>
          </div>
        </div>

        <%!-- SOL Multiplier --%>
        <div class={["p-5", if(sol_balance <= 0, do: "bg-gradient-to-br from-[#fef9c3]/30 to-transparent")]}>
          <div class="flex items-center justify-between mb-3">
            <div class="flex items-center gap-2">
              <div class={["w-7 h-7 rounded-md grid place-items-center", if(sol_balance > 0, do: "bg-black", else: "bg-neutral-200")]}>
                <%= if sol_balance > 0 do %>
                  <img src="https://ik.imagekit.io/blockster/solana-sol-logo.png" alt="SOL" class="w-4 h-4 rounded-full" />
                <% else %>
                  <span class="text-neutral-500 font-bold text-[8px]">SOL</span>
                <% end %>
              </div>
              <div>
                <div class="text-[12px] font-bold text-[#141414]">SOL Balance</div>
                <div class="text-[10px] text-neutral-500"><%= :erlang.float_to_binary(sol_balance * 1.0, decimals: 3) %> SOL</div>
              </div>
            </div>
            <%= if sol_balance > 0 do %>
              <span class="text-[10px] font-bold text-[#22C55E] uppercase tracking-wider">Active</span>
            <% else %>
              <span class="text-[10px] font-bold text-[#a16207] uppercase tracking-wider">Fund wallet</span>
            <% end %>
          </div>
          <div class={["font-mono font-bold text-[26px] leading-none mb-2", if(sol_balance > 0, do: "text-[#141414]", else: "text-neutral-400")]}><%= format_multiplier(@sol_multiplier) %>&times;</div>
          <% sol_pct = min(Float.round(@sol_multiplier / 5 * 100, 0), 100) %>
          <div class="h-1.5 bg-[#f3f4f6] rounded-full overflow-hidden mb-2"><div class={["h-full rounded-full", if(sol_balance > 0, do: "bg-gradient-to-r from-[#00FFA3] to-[#00DC82]", else: "bg-gradient-to-r from-[#d4d4d2] to-[#b4b4b2]")]} style={"width: #{sol_pct}%"}></div></div>
          <div class="flex items-center justify-between text-[10px] text-neutral-500 font-mono">
            <span>0&times;</span>
            <span class="text-neutral-400">max 5&times; at 10 SOL</span>
          </div>
        </div>

        <%!-- Email Multiplier --%>
        <div class={["p-5", unless(@member.email_verified, do: "bg-gradient-to-br from-[#fef9c3]/30 to-transparent")]}>
          <div class="flex items-center justify-between mb-3">
            <div class="flex items-center gap-2">
              <div class={["w-7 h-7 rounded-md grid place-items-center", if(@member.email_verified, do: "bg-[#22C55E]", else: "bg-neutral-200")]}>
                <svg class={["w-3.5 h-3.5", if(@member.email_verified, do: "text-white", else: "text-neutral-500")]} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
              </div>
              <div>
                <div class="text-[12px] font-bold text-[#141414]">Email</div>
                <div class={["text-[10px]", if(@member.email_verified, do: "text-neutral-500", else: "text-[#a16207]")]}>
                  <%= if @member.email_verified, do: "Verified", else: "Not verified" %>
                </div>
              </div>
            </div>
            <%= if @member.email_verified do %>
              <span class="text-[10px] font-bold text-[#22C55E] uppercase tracking-wider">Verified</span>
            <% else %>
              <button phx-click="open_email_verification" class="text-[10px] font-bold text-[#a16207] hover:text-[#7c2d12] uppercase tracking-wider transition-colors cursor-pointer">Verify &rarr;</button>
            <% end %>
          </div>
          <div class={["font-mono font-bold text-[26px] leading-none mb-2", if(@member.email_verified, do: "text-[#141414]", else: "text-neutral-400")]}><%= format_multiplier(@email_multiplier) %>&times;</div>
          <% email_pct = min(Float.round(@email_multiplier / 2 * 100, 0), 100) %>
          <div class="h-1.5 bg-[#f3f4f6] rounded-full overflow-hidden mb-2"><div class={["h-full rounded-full", if(@member.email_verified, do: "bg-gradient-to-r from-[#CAFC00] to-[#9ED600]", else: "bg-gradient-to-r from-[#d4d4d2] to-[#b4b4b2]")]} style={"width: #{email_pct}%"}></div></div>
          <div class="flex items-center justify-between text-[10px] text-neutral-500 font-mono">
            <span>0.5&times;</span>
            <span class={if(@member.email_verified, do: "text-neutral-400", else: "text-[#a16207]")}>max 2&times;<%= if @member.email_verified, do: " ✓", else: " when verified" %></span>
          </div>
        </div>
      </div>

      <%!-- Footer formula --%>
      <div class="px-6 py-4 bg-neutral-50 border-t border-neutral-100 flex items-center justify-between flex-wrap gap-3">
        <div class="font-mono text-[11px] text-neutral-500">
          <span class={if(@x_connection, do: "text-[#141414] font-bold", else: "text-neutral-400")}><%= format_multiplier(@x_multiplier) %></span> &times;
          <span class={if(@member.phone_verified, do: "text-[#141414] font-bold", else: "text-neutral-400")}><%= format_multiplier(@phone_multiplier) %></span> &times;
          <span class={if(@sol_multiplier > 0, do: "text-[#141414] font-bold", else: "text-neutral-400")}><%= format_multiplier(@sol_multiplier) %></span> &times;
          <span class={if(@member.email_verified, do: "text-[#141414] font-bold", else: "text-neutral-400")}><%= format_multiplier(@email_multiplier) %></span>
          = <span class="text-[#141414] font-bold text-[14px]"><%= format_multiplier(@overall_multiplier) %>&times;</span>
        </div>
        <%= if @overall_multiplier == 0 do %>
          <div class="text-[11px] text-[#a16207] font-bold">Deposit at least 0.1 SOL into your connected wallet to start earning BUX</div>
        <% else %>
          <div class="text-[10px] text-neutral-500">Multipliers compound. Higher scores = more BUX per article.</div>
        <% end %>
      </div>
    </div>
  </section>
</main>

<%!-- ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
     STICKY TABS
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ --%>
<div class="ds-profile-tabs sticky top-[84px] z-[15] border-y border-neutral-200/70" style="background: rgba(250, 250, 249, 0.95); backdrop-filter: saturate(180%) blur(12px); -webkit-backdrop-filter: saturate(180%) blur(12px);">
  <%!-- Desktop tabs --%>
  <div class="max-w-[1280px] mx-auto px-6 hidden md:flex items-center gap-8 overflow-x-auto">
    <% tabs = [
      {"activity", "Activity", length(@all_activities)},
      {"following", "Following", length(@followed_hubs)},
      {"refer", "Refer", Map.get(@referral_stats || %{}, :total_referrals, 0)},
      {"rewards", "Rewards", nil},
      {"settings", "Settings", nil}
    ] %>
    <%= for {tab_id, tab_label, tab_count} <- tabs do %>
      <button
        phx-click="switch_tab"
        phx-value-tab={tab_id}
        class={[
          "relative py-4 px-1 text-[14px] whitespace-nowrap transition-colors cursor-pointer",
          if(@active_tab == tab_id, do: "text-[#141414] font-bold", else: "text-[#6B7280] hover:text-[#141414]")
        ]}
      >
        <%= tab_label %>
        <%= if tab_count do %>
          <span class="ml-1.5 font-mono text-[11px] opacity-50"><%= tab_count %></span>
        <% end %>
        <%= if @active_tab == tab_id do %>
          <span class="absolute bottom-0 left-0 right-0 h-0.5 bg-[#CAFC00]"></span>
        <% end %>
      </button>
    <% end %>
  </div>
  <%!-- Mobile dropdown --%>
  <div class="md:hidden max-w-[1280px] mx-auto px-6 py-3">
    <form phx-change="switch_tab_select">
      <select name="tab" class="w-full bg-white border border-neutral-200 rounded-xl px-4 py-2.5 text-[13px] font-bold text-[#141414] cursor-pointer">
        <option value="activity" selected={@active_tab == "activity"}>Activity</option>
        <option value="following" selected={@active_tab == "following"}>Following</option>
        <option value="refer" selected={@active_tab == "refer"}>Refer</option>
        <option value="rewards" selected={@active_tab == "rewards"}>Rewards</option>
        <option value="settings" selected={@active_tab == "settings"}>Settings</option>
      </select>
    </form>
  </div>
</div>

<main class="max-w-[1280px] mx-auto px-6">
  <%!-- ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
       ACTIVITY TAB
  ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ --%>
  <%= if @active_tab == "activity" do %>
    <section class="ds-activity-tab pt-10 pb-10">
      <%!-- Period filter + total earned --%>
      <div class="flex items-end justify-between flex-wrap gap-4 mb-6">
        <div>
          <BlocksterV2Web.DesignSystem.eyebrow class="mb-1">
            Total earned &middot; <%= case @time_period do
              "24h" -> "24 hours"
              "7d" -> "7 days"
              "30d" -> "30 days"
              "all" -> "all time"
            end %>
          </BlocksterV2Web.DesignSystem.eyebrow>
          <div class="flex items-baseline gap-2">
            <span class="font-mono font-bold text-[44px] text-[#141414] leading-none tracking-tight tabular-nums">+ <%= format_number(@total_bux) %></span>
            <span class="text-[14px] text-neutral-500">BUX</span>
          </div>
        </div>
        <div class="flex items-center gap-1.5 flex-wrap">
          <%= for {period, label} <- [{"24h", "24H"}, {"7d", "7D"}, {"30d", "30D"}, {"all", "ALL"}] do %>
            <button
              phx-click="set_time_period"
              phx-value-period={period}
              class={[
                "px-3.5 py-1.5 rounded-full font-mono text-[11px] font-semibold tracking-[0.04em] transition-all cursor-pointer whitespace-nowrap",
                if(@time_period == period,
                  do: "bg-[#141414] text-white border border-[#141414]",
                  else: "bg-white border border-[#e5e5e2] text-[#6B7280] hover:border-[#141414] hover:text-[#141414]")
              ]}
            ><%= label %></button>
          <% end %>
        </div>
      </div>

      <%!-- Activity table --%>
      <div class="bg-white rounded-2xl border border-neutral-200/70 shadow-[0_1px_3px_rgba(0,0,0,0.04)] overflow-hidden">
        <%!-- Header row --%>
        <div class="grid grid-cols-[120px_1fr_140px] px-5 py-3 bg-neutral-50/70 border-b border-neutral-100 text-[10px] uppercase tracking-[0.14em] text-neutral-500 font-bold">
          <div>Date</div>
          <div>Activity</div>
          <div class="text-right">Reward</div>
        </div>

        <div class="divide-y divide-neutral-100">
          <%= for activity <- @activities do %>
            <div class="px-5 py-4 transition-colors hover:bg-black/[0.02]">
              <div class="grid grid-cols-[120px_1fr_140px] items-center gap-3">
                <div class="font-mono text-[11px] text-neutral-500"><%= format_relative_time(activity.timestamp) %></div>
                <div class="flex items-center gap-3">
                  <%!-- Activity icon --%>
                  <div class={[
                    "w-8 h-8 rounded-lg grid place-items-center shrink-0",
                    case activity.type do
                      :read -> "bg-[#CAFC00]/15 border border-[#CAFC00]/30"
                      :video -> "bg-[#CAFC00]/15 border border-[#CAFC00]/30"
                      :x_share -> "bg-black/5 border border-black/10"
                      :notification -> "bg-[#7D00FF]/12 border border-[#7D00FF]/25"
                      _ -> "bg-[#CAFC00]/15 border border-[#CAFC00]/30"
                    end
                  ]}>
                    <%= case activity.type do %>
                      <% :read -> %>
                        <svg class="w-4 h-4 text-[#141414]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
                      <% :video -> %>
                        <svg class="w-4 h-4 text-[#141414]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="5 3 19 12 5 21 5 3"/></svg>
                      <% :x_share -> %>
                        <svg class="w-4 h-4 text-[#141414]" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
                      <% _ -> %>
                        <svg class="w-4 h-4 text-[#7D00FF]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                    <% end %>
                  </div>
                  <div class="min-w-0">
                    <div class="text-[13px] font-bold text-[#141414] leading-tight truncate">
                      <%= case activity.type do %>
                        <% :read -> %>Read "<%= activity[:post_title] || "Article" %>"
                        <% :video -> %>Watched "<%= activity[:post_title] || "Video" %>"
                        <% :x_share -> %>Shared on X
                        <% :notification -> %><%= activity[:label] || "Activity" %>
                        <% _ -> %><%= activity[:label] || "Activity" %>
                      <% end %>
                    </div>
                    <div class="flex items-center gap-1.5 mt-0.5">
                      <%= if activity[:post_slug] do %>
                        <a href={~p"/#{activity.post_slug}"} class="text-[10px] text-neutral-400 hover:text-[#141414] transition-colors">View article &#8599;</a>
                      <% end %>
                    </div>
                  </div>
                </div>
                <div class="text-right">
                  <%= if activity.amount && activity.amount > 0 do %>
                    <div class="font-mono font-bold text-[14px] text-[#22C55E]">+ <%= format_number(activity.amount) %> BUX</div>
                  <% else %>
                    <div class="font-mono text-[12px] text-neutral-400">&mdash;</div>
                  <% end %>
                  <%= if activity[:tx_id] do %>
                    <a href={"https://solscan.io/tx/#{activity.tx_id}?cluster=devnet"} target="_blank" rel="noopener noreferrer" class="text-[9px] font-mono text-neutral-400 hover:text-[#141414] transition-colors">tx &middot; <%= truncate_wallet(activity.tx_id) %></a>
                  <% end %>
                </div>
              </div>
            </div>
          <% end %>
          <%= if @activities == [] do %>
            <div class="px-5 py-12 text-center">
              <div class="text-neutral-400 text-[13px]">No activity yet. Start reading articles to earn BUX!</div>
            </div>
          <% end %>
        </div>

        <%!-- Load more footer --%>
        <%= if length(@activities) > 0 do %>
          <div class="px-5 py-4 border-t border-neutral-100 flex items-center justify-between">
            <div class="text-[11px] text-neutral-500">Showing <%= length(@activities) %> of <%= length(@all_activities) %> activities</div>
          </div>
        <% end %>
      </div>
    </section>
  <% end %>

  <%!-- ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
       FOLLOWING TAB
  ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ --%>
  <%= if @active_tab == "following" do %>
    <section class="ds-following-tab pt-10 pb-12">
      <div class="flex items-end justify-between flex-wrap gap-4 mb-6">
        <div>
          <BlocksterV2Web.DesignSystem.eyebrow class="mb-1">Hubs you follow &middot; <%= length(@followed_hubs) %></BlocksterV2Web.DesignSystem.eyebrow>
          <h2 class="font-bold text-[36px] md:text-[40px] text-[#141414] tracking-[-0.022em] leading-[0.96]">Following</h2>
        </div>
        <div class="flex items-center gap-2">
          <a href={~p"/hubs"} class="inline-flex items-center gap-2 bg-[#0a0a0a] text-white px-4 py-2.5 rounded-full text-[12px] font-bold hover:bg-[#1a1a22] transition-colors">
            Browse all hubs
            <svg class="w-3.5 h-3.5" viewBox="0 0 20 20" fill="none"><path d="M3 10h12m0 0l-4-4m4 4l-4 4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
        </div>
      </div>

      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4">
        <%= for hub <- @followed_hubs do %>
          <div
            class="rounded-2xl p-5 text-white relative overflow-hidden transition-all duration-200 hover:-translate-y-0.5 hover:shadow-xl"
            style={"background: linear-gradient(135deg, #{hub.color_primary || "#6B7280"} 0%, #{hub.color_secondary || "#374151"} 100%); min-height: 240px;"}
          >
            <div class="absolute inset-0 pointer-events-none" style="background: radial-gradient(circle at 80% 20%, rgba(255,255,255,0.18), transparent 60%);"></div>
            <div class="relative z-10 h-full flex flex-col" style="min-height: 200px;">
              <div class="flex items-center justify-between mb-8">
                <div class="w-9 h-9 rounded-md bg-white/15 backdrop-blur grid place-items-center ring-1 ring-white/20">
                  <%= if hub.logo_url do %>
                    <img src={hub.logo_url} alt={hub.name} class="w-5 h-5 rounded" />
                  <% else %>
                    <span class="text-white font-bold text-[14px]"><%= hub.token || String.first(hub.name) %></span>
                  <% end %>
                </div>
                <button
                  phx-click="unfollow_hub"
                  phx-value-hub-id={hub.id}
                  class="w-7 h-7 rounded-full bg-white/15 backdrop-blur grid place-items-center hover:bg-white/30 transition-colors cursor-pointer"
                  title="Unfollow"
                >
                  <svg class="w-3.5 h-3.5 text-white" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                </button>
              </div>
              <a href={~p"/hub/#{hub.slug}"} class="font-bold text-[20px] tracking-tight mb-1 hover:underline"><%= hub.name %></a>
              <p class="text-white/75 text-[11px] line-clamp-2 mb-4 mt-auto">
                <%= if Ecto.assoc_loaded?(hub.posts) do %>
                  <%= length(hub.posts) %> posts
                <% end %>
              </p>
              <div class="flex items-center justify-between mt-auto">
                <div class="flex items-center gap-3">
                  <div>
                    <span class="text-[14px] font-bold tabular-nums">
                      <%= if Ecto.assoc_loaded?(hub.posts), do: length(hub.posts), else: "—" %>
                    </span>
                    <span class="text-[10px] text-white/65">posts</span>
                  </div>
                </div>
              </div>
            </div>
          </div>
        <% end %>

        <%!-- Discover more card --%>
        <a href={~p"/hubs"} class="rounded-2xl p-5 bg-white border-2 border-dashed border-neutral-300 hover:border-[#141414] grid place-items-center text-center group transition-all duration-200 cursor-pointer" style="min-height: 240px;">
          <div>
            <div class="w-12 h-12 rounded-full bg-neutral-100 grid place-items-center mx-auto mb-3 group-hover:bg-[#CAFC00] transition-colors">
              <svg class="w-5 h-5 text-neutral-600 group-hover:text-black transition-colors" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
            </div>
            <h3 class="font-bold text-[14px] text-[#141414] mb-1">Discover more</h3>
            <p class="text-[10px] text-neutral-500">Browse all hubs</p>
          </div>
        </a>
      </div>

      <%= if @followed_hubs == [] do %>
        <div class="bg-white rounded-2xl border border-neutral-200/70 p-12 text-center mt-4">
          <div class="text-neutral-400 text-[13px] mb-4">You're not following any hubs yet.</div>
          <a href={~p"/hubs"} class="inline-flex items-center gap-2 bg-[#0a0a0a] text-white px-5 py-2.5 rounded-full text-[12px] font-bold hover:bg-[#1a1a22] transition-colors">Browse hubs</a>
        </div>
      <% end %>
    </section>
  <% end %>

  <%!-- ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
       REFER TAB
  ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ --%>
  <%= if @active_tab == "refer" do %>
    <section class="ds-refer-tab pt-10 pb-12">
      <div class="mb-6">
        <BlocksterV2Web.DesignSystem.eyebrow class="mb-1">Earn from your network</BlocksterV2Web.DesignSystem.eyebrow>
        <h2 class="font-bold text-[36px] md:text-[40px] text-[#141414] tracking-[-0.022em] leading-[0.96]">Refer friends</h2>
      </div>

      <%!-- Referral link card --%>
      <div class="bg-white rounded-2xl border border-neutral-200/70 shadow-[0_1px_3px_rgba(0,0,0,0.04)] p-7 mb-6 relative overflow-hidden">
        <div class="absolute -top-24 -right-24 w-72 h-72 bg-[#CAFC00]/10 rounded-full blur-3xl pointer-events-none"></div>
        <div class="relative grid grid-cols-12 gap-6 items-center">
          <div class="col-span-12 md:col-span-7">
            <div class="text-[10px] font-bold uppercase tracking-[0.14em] text-neutral-500 mb-3">Your referral link</div>
            <div class="flex items-center gap-2 bg-neutral-50 border border-neutral-200 rounded-xl px-4 py-3">
              <svg class="w-4 h-4 text-neutral-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
              <code class="font-mono text-[13px] text-[#141414] flex-1 truncate"><%= @referral_link %></code>
              <button
                id="copy-referral-link"
                phx-hook="CopyToClipboard"
                data-copy-text={@referral_link}
                class="bg-[#0a0a0a] text-white px-4 py-1.5 rounded-full text-[11px] font-bold hover:bg-[#1a1a22] transition-colors shrink-0 cursor-pointer"
              >Copy</button>
            </div>
            <p class="text-neutral-600 text-[12px] mt-3 max-w-[480px] leading-[1.55]">
              Earn <span class="text-[#141414] font-bold">500 BUX</span> for every signup. Your friend gets <span class="text-[#141414] font-bold">250 BUX</span> too. Plus earn <span class="text-[#141414] font-bold">0.2%</span> of every losing bet they place &mdash; forever.
            </p>
          </div>
          <div class="col-span-12 md:col-span-5 grid grid-cols-2 gap-3">
            <div class="bg-neutral-50 border border-neutral-200/70 rounded-xl p-4 text-center">
              <div class="font-mono font-bold text-[26px] text-[#141414] leading-none tabular-nums"><%= Map.get(@referral_stats || %{}, :total_referrals, 0) %></div>
              <div class="text-[9px] uppercase tracking-[0.14em] text-neutral-500 mt-1.5">Total referrals</div>
            </div>
            <div class="bg-neutral-50 border border-neutral-200/70 rounded-xl p-4 text-center">
              <div class="font-mono font-bold text-[26px] text-[#141414] leading-none tabular-nums"><%= Map.get(@referral_stats || %{}, :verified_referrals, 0) %></div>
              <div class="text-[9px] uppercase tracking-[0.14em] text-neutral-500 mt-1.5">Verified</div>
            </div>
            <div class="bg-neutral-50 border border-neutral-200/70 rounded-xl p-4 text-center">
              <div class="font-mono font-bold text-[26px] text-[#141414] leading-none tabular-nums"><%= format_number(Map.get(@referral_stats || %{}, :total_bux_earned, 0)) %></div>
              <div class="text-[9px] uppercase tracking-[0.14em] text-neutral-500 mt-1.5">BUX earned</div>
            </div>
            <div class="bg-neutral-50 border border-neutral-200/70 rounded-xl p-4 text-center">
              <div class="font-mono font-bold text-[26px] text-[#141414] leading-none tabular-nums"><%= format_referral_number(Map.get(@referral_stats || %{}, :total_sol_earned, 0)) %></div>
              <div class="text-[9px] uppercase tracking-[0.14em] text-neutral-500 mt-1.5">SOL earned</div>
            </div>
          </div>
        </div>
      </div>

      <%!-- Referral earnings table --%>
      <div class="bg-white rounded-2xl border border-neutral-200/70 shadow-[0_1px_3px_rgba(0,0,0,0.04)] overflow-hidden">
        <div class="px-5 py-4 border-b border-neutral-100 flex items-center justify-between flex-wrap gap-2">
          <div class="flex items-center gap-2">
            <span class="w-1.5 h-1.5 rounded-full bg-[#22C55E] animate-[pulse-dot_1.6s_cubic-bezier(0.4,0,0.6,1)_infinite]"></span>
            <span class="text-[10px] uppercase tracking-[0.14em] text-neutral-500 font-bold">Referral earnings &middot; Live</span>
          </div>
        </div>

        <div class="hidden md:grid grid-cols-[110px_1fr_120px_140px_80px] px-5 py-3 bg-neutral-50/70 border-b border-neutral-100 text-[10px] uppercase tracking-[0.14em] text-neutral-500 font-bold">
          <div>Type</div>
          <div>From</div>
          <div class="text-right">Amount</div>
          <div class="text-right">Time</div>
          <div class="text-right">TX</div>
        </div>

        <div id="referral-earnings-list" class="divide-y divide-neutral-100" phx-hook="InfiniteScroll" data-event="load_more_earnings">
          <%= for earning <- @referral_earnings do %>
            <div class="grid grid-cols-1 md:grid-cols-[110px_1fr_120px_140px_80px] px-5 py-4 items-center gap-2 md:gap-0 transition-colors hover:bg-black/[0.02]">
              <div>
                <span class={[
                  "text-[9px] font-bold uppercase tracking-wider px-2 py-1 rounded-full",
                  case earning.type do
                    :signup -> "bg-[#CAFC00] text-black"
                    :phone_verified -> "bg-[#CAFC00] text-black"
                    :bux_bet_loss -> "bg-[#7D00FF]/15 text-[#7D00FF]"
                    :sol_bet_loss -> "bg-gradient-to-br from-[#00FFA3]/15 to-[#00DC82]/10 text-[#0a3d2f]"
                    _ -> "bg-neutral-100 text-neutral-600"
                  end
                ]}><%= earning_type_label(earning.type) %></span>
              </div>
              <div class="flex items-center gap-2 min-w-0">
                <BlocksterV2Web.DesignSystem.author_avatar
                  initials={user_initials_from_name(earning.referee_username || "?")}
                  size="sm"
                />
                <div class="min-w-0">
                  <div class="text-[12px] font-bold text-[#141414] truncate"><%= earning.referee_username || "User" %></div>
                  <div class="text-[10px] text-neutral-500 font-mono truncate"><%= truncate_wallet(earning.referee_wallet) %></div>
                </div>
              </div>
              <div class="text-right font-mono font-bold text-[14px] text-[#22C55E]">
                + <%= format_referral_number(earning.amount) %> <%= if earning.token == "SOL", do: "SOL", else: "BUX" %>
              </div>
              <div class="text-right text-[11px] font-mono text-neutral-500"><%= format_relative_time(earning.created_at) %></div>
              <div class="text-right">
                <%= if earning.tx_hash do %>
                  <a href={"https://solscan.io/tx/#{earning.tx_hash}?cluster=devnet"} target="_blank" rel="noopener noreferrer" class="text-[10px] font-mono text-neutral-400 hover:text-[#141414] transition-colors"><%= truncate_wallet(earning.tx_hash) %></a>
                <% end %>
              </div>
            </div>
          <% end %>
          <%= if @referral_earnings == [] do %>
            <div class="px-5 py-12 text-center">
              <div class="text-neutral-400 text-[13px]">No referral earnings yet. Share your link to start earning!</div>
            </div>
          <% end %>
        </div>

        <%= if length(@referral_earnings) > 0 do %>
          <div class="px-5 py-4 border-t border-neutral-100 flex items-center justify-between">
            <div class="text-[11px] text-neutral-500">Showing <%= length(@referral_earnings) %> referral payouts</div>
            <a href={~p"/notifications/referrals"} class="text-[12px] font-bold text-[#141414] hover:text-[#7D00FF] transition-colors">View full referral dashboard &rarr;</a>
          </div>
        <% end %>
      </div>
    </section>
  <% end %>

  <%!-- ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
       REWARDS TAB (NEW)
  ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ --%>
  <%= if @active_tab == "rewards" do %>
    <section class="ds-rewards-tab pt-10 pb-12">
      <div class="mb-6">
        <BlocksterV2Web.DesignSystem.eyebrow class="mb-1">All-time BUX earnings broken down</BlocksterV2Web.DesignSystem.eyebrow>
        <h2 class="font-bold text-[36px] md:text-[40px] text-[#141414] tracking-[-0.022em] leading-[0.96]">Rewards</h2>
      </div>

      <%
        # Compute reward breakdown from all activities
        all_acts = @all_activities
        read_acts = Enum.filter(all_acts, &(&1.type == :read))
        video_acts = Enum.filter(all_acts, &(&1.type == :video))
        share_acts = Enum.filter(all_acts, &(&1.type == :x_share))
        notif_acts = Enum.filter(all_acts, &(&1.type == :notification))
        read_bux = read_acts |> Enum.map(& &1.amount) |> Enum.filter(&is_number/1) |> Enum.sum()
        video_bux = video_acts |> Enum.map(& &1.amount) |> Enum.filter(&is_number/1) |> Enum.sum()
        share_bux = share_acts |> Enum.map(& &1.amount) |> Enum.filter(&is_number/1) |> Enum.sum()
        notif_bux = notif_acts |> Enum.map(& &1.amount) |> Enum.filter(&is_number/1) |> Enum.sum()
        referral_bux = Map.get(@referral_stats || %{}, :total_bux_earned, 0) || 0
        total_lifetime = read_bux + video_bux + share_bux + notif_bux + referral_bux
        safe_total = max(total_lifetime, 1)
      %>

      <div class="grid grid-cols-12 gap-4 mb-6">
        <%!-- Big total card --%>
        <div class="col-span-12 md:col-span-5 bg-white rounded-2xl border border-neutral-200/70 shadow-[0_1px_3px_rgba(0,0,0,0.04)] p-7 relative overflow-hidden">
          <div class="absolute -top-20 -right-20 w-72 h-72 bg-[#CAFC00]/12 rounded-full blur-3xl pointer-events-none"></div>
          <div class="relative">
            <div class="text-[10px] font-bold uppercase tracking-[0.14em] text-neutral-500 mb-3">Lifetime BUX earned</div>
            <div class="flex items-baseline gap-2 mb-2">
              <span class="font-mono font-bold text-[64px] text-[#141414] leading-none tracking-tight tabular-nums"><%= format_number(total_lifetime) %></span>
              <span class="text-[16px] text-neutral-500">BUX</span>
            </div>
            <div class="text-[12px] text-neutral-500">Use BUX to enter airdrops &amp; play games</div>
          </div>
        </div>

        <%!-- Source breakdown --%>
        <div class="col-span-12 md:col-span-7 bg-white rounded-2xl border border-neutral-200/70 shadow-[0_1px_3px_rgba(0,0,0,0.04)] p-7">
          <div class="text-[10px] font-bold uppercase tracking-[0.14em] text-neutral-500 mb-5">By source</div>

          <div class="space-y-4">
            <%!-- Reading --%>
            <div>
              <div class="flex items-center justify-between mb-1.5">
                <div class="flex items-center gap-2">
                  <div class="w-6 h-6 rounded bg-[#CAFC00]/15 border border-[#CAFC00]/30 grid place-items-center">
                    <svg class="w-3 h-3 text-[#141414]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
                  </div>
                  <span class="text-[13px] font-bold text-[#141414]">Reading articles</span>
                  <span class="text-[10px] text-neutral-400 font-mono"><%= length(read_acts) %> articles</span>
                </div>
                <span class="font-mono font-bold text-[16px] text-[#141414]"><%= format_number(read_bux) %> <span class="text-[10px] text-neutral-400">BUX &middot; <%= Float.round(read_bux / safe_total * 100, 1) %>%</span></span>
              </div>
              <div class="h-1.5 bg-[#f3f4f6] rounded-full overflow-hidden"><div class="h-full rounded-full bg-gradient-to-r from-[#CAFC00] to-[#9ED600]" style={"width: #{Float.round(read_bux / safe_total * 100, 1)}%"}></div></div>
            </div>

            <%!-- X Shares --%>
            <div>
              <div class="flex items-center justify-between mb-1.5">
                <div class="flex items-center gap-2">
                  <div class="w-6 h-6 rounded bg-black grid place-items-center">
                    <svg class="w-3 h-3 text-white" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
                  </div>
                  <span class="text-[13px] font-bold text-[#141414]">X shares</span>
                  <span class="text-[10px] text-neutral-400 font-mono"><%= length(share_acts) %> shares</span>
                </div>
                <span class="font-mono font-bold text-[16px] text-[#141414]"><%= format_number(share_bux) %> <span class="text-[10px] text-neutral-400">BUX &middot; <%= Float.round(share_bux / safe_total * 100, 1) %>%</span></span>
              </div>
              <div class="h-1.5 bg-[#f3f4f6] rounded-full overflow-hidden"><div class="h-full rounded-full bg-gradient-to-r from-[#7D00FF] to-[#4A00B8]" style={"width: #{Float.round(share_bux / safe_total * 100, 1)}%"}></div></div>
            </div>

            <%!-- Referrals --%>
            <div>
              <div class="flex items-center justify-between mb-1.5">
                <div class="flex items-center gap-2">
                  <div class="w-6 h-6 rounded bg-[#22C55E]/15 border border-[#22C55E]/30 grid place-items-center">
                    <svg class="w-3 h-3 text-[#15803d]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="8.5" cy="7" r="4"/></svg>
                  </div>
                  <span class="text-[13px] font-bold text-[#141414]">Referrals</span>
                  <span class="text-[10px] text-neutral-400 font-mono"><%= Map.get(@referral_stats || %{}, :verified_referrals, 0) %> verified</span>
                </div>
                <span class="font-mono font-bold text-[16px] text-[#141414]"><%= format_number(referral_bux) %> <span class="text-[10px] text-neutral-400">BUX &middot; <%= Float.round(referral_bux / safe_total * 100, 1) %>%</span></span>
              </div>
              <div class="h-1.5 bg-[#f3f4f6] rounded-full overflow-hidden"><div class="h-full rounded-full bg-gradient-to-r from-[#00FFA3] to-[#00DC82]" style={"width: #{Float.round(referral_bux / safe_total * 100, 1)}%"}></div></div>
            </div>

            <%!-- Other (verification bonuses, etc) --%>
            <div>
              <div class="flex items-center justify-between mb-1.5">
                <div class="flex items-center gap-2">
                  <div class="w-6 h-6 rounded bg-[#7D00FF]/15 border border-[#7D00FF]/30 grid place-items-center">
                    <svg class="w-3 h-3 text-[#7D00FF]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                  </div>
                  <span class="text-[13px] font-bold text-[#141414]">Other bonuses</span>
                </div>
                <span class="font-mono font-bold text-[16px] text-[#141414]"><%= format_number(notif_bux + video_bux) %> <span class="text-[10px] text-neutral-400">BUX &middot; <%= Float.round((notif_bux + video_bux) / safe_total * 100, 1) %>%</span></span>
              </div>
              <div class="h-1.5 bg-[#f3f4f6] rounded-full overflow-hidden"><div class="h-full rounded-full bg-gradient-to-r from-[#7D00FF] to-[#4A00B8]" style={"width: #{Float.round((notif_bux + video_bux) / safe_total * 100, 1)}%"}></div></div>
            </div>
          </div>
        </div>
      </div>
    </section>
  <% end %>

  <%!-- ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
       SETTINGS TAB
  ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ --%>
  <%= if @active_tab == "settings" do %>
    <section class="ds-settings-tab pt-10 pb-12">
      <div class="mb-6">
        <BlocksterV2Web.DesignSystem.eyebrow class="mb-1">Account & connections</BlocksterV2Web.DesignSystem.eyebrow>
        <h2 class="font-bold text-[36px] md:text-[40px] text-[#141414] tracking-[-0.022em] leading-[0.96]">Settings</h2>
      </div>

      <div class="grid grid-cols-12 gap-6">
        <%!-- Account details (left) --%>
        <div class="col-span-12 md:col-span-7 bg-white rounded-2xl border border-neutral-200/70 shadow-[0_1px_3px_rgba(0,0,0,0.04)] overflow-hidden">
          <div class="px-6 py-4 border-b border-neutral-100">
            <div class="text-[10px] font-bold uppercase tracking-[0.14em] text-neutral-500 mb-1">Account</div>
            <h3 class="font-bold text-[18px] text-[#141414]">Account details</h3>
          </div>
          <div class="divide-y divide-neutral-100">
            <%!-- Username --%>
            <div class="px-6 py-4 flex items-center justify-between gap-3">
              <div class="min-w-0 flex-1">
                <div class="text-[10px] uppercase tracking-[0.14em] text-neutral-500 mb-0.5">Username</div>
                <%= if @editing_username do %>
                  <form phx-submit="save_username" class="flex items-center gap-2">
                    <input
                      type="text"
                      name="username"
                      value={@username_form["username"]}
                      phx-change="update_username_form"
                      class="flex-1 border border-neutral-200 rounded-lg px-3 py-1.5 text-[14px] font-bold text-[#141414] focus:outline-none focus:border-[#CAFC00]"
                      autofocus
                    />
                    <button type="submit" class="bg-[#0a0a0a] text-white px-3 py-1.5 rounded-full text-[11px] font-bold hover:bg-[#1a1a22] transition-colors cursor-pointer">Save</button>
                    <button type="button" phx-click="cancel_edit_username" class="text-[11px] text-neutral-500 hover:text-[#141414] transition-colors cursor-pointer">Cancel</button>
                  </form>
                <% else %>
                  <div class="text-[14px] font-bold text-[#141414]"><%= @member.username || "—" %></div>
                <% end %>
              </div>
              <%= unless @editing_username do %>
                <button phx-click="edit_username" class="text-[12px] text-neutral-500 hover:text-[#141414] transition-colors cursor-pointer">Edit</button>
              <% end %>
            </div>

            <%!-- Profile URL --%>
            <div class="px-6 py-4 flex items-center justify-between gap-3">
              <div class="min-w-0">
                <div class="text-[10px] uppercase tracking-[0.14em] text-neutral-500 mb-0.5">Profile URL</div>
                <div class="text-[13px] font-mono text-[#141414] truncate">blockster.com/member/<%= @member.slug || @member.wallet_address %></div>
              </div>
              <button
                id="copy-profile-url"
                phx-hook="CopyToClipboard"
                data-copy-text={"https://blockster.com/member/#{@member.slug || @member.wallet_address}"}
                class="text-neutral-400 hover:text-[#141414] transition-colors cursor-pointer"
                title="Copy"
              >
                <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
              </button>
            </div>

            <%!-- Wallet --%>
            <div class="px-6 py-4 flex items-center justify-between gap-3">
              <div class="min-w-0">
                <div class="text-[10px] uppercase tracking-[0.14em] text-neutral-500 mb-0.5">Wallet address</div>
                <div class="text-[13px] font-mono text-[#141414] truncate"><%= truncate_wallet(@member.wallet_address) %></div>
              </div>
              <div class="flex items-center gap-3">
                <a href={"https://solscan.io/account/#{@member.wallet_address}?cluster=devnet"} target="_blank" rel="noopener noreferrer" class="text-[11px] text-neutral-500 hover:text-[#141414] transition-colors">Solscan &#8599;</a>
                <button
                  id="copy-wallet-settings"
                  phx-hook="CopyToClipboard"
                  data-copy-text={@member.wallet_address}
                  class="text-neutral-400 hover:text-[#141414] transition-colors cursor-pointer"
                >
                  <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
                </button>
              </div>
            </div>

            <%!-- Email --%>
            <div class="px-6 py-4 flex items-center justify-between gap-3">
              <div class="min-w-0 flex-1">
                <div class="flex items-center gap-2 mb-0.5">
                  <div class="text-[10px] uppercase tracking-[0.14em] text-neutral-500">Email</div>
                  <%= unless @member.email_verified do %>
                    <span class="bg-[#facc15]/15 text-[#a16207] border border-[#facc15]/40 text-[9px] font-bold uppercase tracking-wider px-1.5 py-0.5 rounded-full">Unverified</span>
                  <% end %>
                </div>
                <div class="text-[14px] text-neutral-600"><%= @member.email || @member.pending_email || "No email set" %></div>
                <%= unless @member.email_verified do %>
                  <div class="text-[10px] text-[#a16207] mt-0.5">Verify your email to unlock 2&times; BUX multiplier</div>
                <% end %>
              </div>
              <%= unless @member.email_verified do %>
                <button phx-click="open_email_verification" class="bg-[#0a0a0a] text-white text-[11px] font-bold px-3 py-1.5 rounded-full hover:bg-[#1a1a22] transition-colors shrink-0 cursor-pointer">Verify</button>
              <% end %>
            </div>

            <%!-- Auth method --%>
            <div class="px-6 py-4 flex items-center justify-between gap-3">
              <div>
                <div class="text-[10px] uppercase tracking-[0.14em] text-neutral-500 mb-0.5">Authentication method</div>
                <div class="text-[14px] text-[#141414]">Solana wallet</div>
              </div>
              <span class="text-[11px] text-neutral-400">Wallet Standard</span>
            </div>

            <%!-- Member since --%>
            <div class="px-6 py-4 flex items-center justify-between gap-3">
              <div>
                <div class="text-[10px] uppercase tracking-[0.14em] text-neutral-500 mb-0.5">Member since</div>
                <div class="text-[14px] text-[#141414]"><%= Calendar.strftime(@member.inserted_at, "%B %d, %Y") %></div>
              </div>
              <% days_ago = NaiveDateTime.diff(NaiveDateTime.utc_now(), @member.inserted_at, :second) |> div(86400) %>
              <span class="text-[11px] text-neutral-400"><%= days_ago %> days ago</span>
            </div>
          </div>
        </div>

        <%!-- Connected accounts (right) --%>
        <div class="col-span-12 md:col-span-5">
          <div class="bg-white rounded-2xl border border-neutral-200/70 shadow-[0_1px_3px_rgba(0,0,0,0.04)] overflow-hidden mb-4">
            <div class="px-6 py-4 border-b border-neutral-100">
              <div class="text-[10px] font-bold uppercase tracking-[0.14em] text-neutral-500 mb-1">Social</div>
              <h3 class="font-bold text-[18px] text-[#141414]">Connected accounts</h3>
            </div>
            <div class="divide-y divide-neutral-100">
              <%!-- X --%>
              <div class="px-6 py-4 flex items-center justify-between gap-3">
                <div class="flex items-center gap-3 min-w-0">
                  <div class="w-9 h-9 rounded-full bg-black grid place-items-center shrink-0">
                    <svg class="w-4 h-4 text-white" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
                  </div>
                  <div class="min-w-0">
                    <div class="text-[13px] font-bold text-[#141414]">X (Twitter)</div>
                    <div class="text-[11px] text-neutral-500">
                      <%= if @x_connection, do: "@#{@x_connection.username} · Connected", else: "Not connected · Earn up to 10× multiplier" %>
                    </div>
                  </div>
                </div>
                <%= if @x_connection do %>
                  <a href={~p"/auth/x/disconnect"} method="delete" class="text-[10px] text-[#EF4444] hover:text-[#7f1d1d] transition-colors shrink-0 cursor-pointer">Disconnect</a>
                <% else %>
                  <a href={~p"/auth/x"} class="bg-[#0a0a0a] text-white text-[11px] font-bold px-3 py-1.5 rounded-full hover:bg-[#1a1a22] transition-colors shrink-0">Connect</a>
                <% end %>
              </div>

              <%!-- Telegram --%>
              <div class="px-6 py-4 flex items-center justify-between gap-3">
                <div class="flex items-center gap-3 min-w-0">
                  <div class="w-9 h-9 rounded-full bg-[#26A5E4] grid place-items-center shrink-0">
                    <svg class="w-4 h-4 text-white" viewBox="0 0 24 24" fill="currentColor"><path d="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0a12 12 0 0 0-.056 0zm4.962 7.224c.1-.002.321.023.464.141a.506.506 0 0 1 .171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.48.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"/></svg>
                  </div>
                  <div class="min-w-0">
                    <div class="text-[13px] font-bold text-[#141414]">Telegram</div>
                    <div class="text-[11px] text-neutral-500">
                      <%= if @telegram_connected, do: "@#{@telegram_username} · Connected", else: "Not connected · Earn 500 BUX" %>
                    </div>
                  </div>
                </div>
                <%= if @telegram_connected do %>
                  <span class="text-[10px] font-bold text-[#15803d] uppercase tracking-wider shrink-0">Connected &#10003;</span>
                <% else %>
                  <button phx-click="connect_telegram" class="bg-[#26A5E4] text-white text-[11px] font-bold px-3 py-1.5 rounded-full hover:bg-[#1d8bc4] transition-colors shrink-0 cursor-pointer">Connect</button>
                <% end %>
              </div>

              <%!-- Email --%>
              <div class="px-6 py-4 flex items-center justify-between gap-3">
                <div class="flex items-center gap-3 min-w-0">
                  <div class={["w-9 h-9 rounded-full grid place-items-center shrink-0", if(@member.email_verified, do: "bg-[#22C55E]", else: "bg-neutral-300")]}>
                    <svg class="w-4 h-4 text-white" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
                  </div>
                  <div class="min-w-0">
                    <div class="text-[13px] font-bold text-[#141414]">Email</div>
                    <div class="text-[11px] text-neutral-500">
                      <%= if @member.email_verified do %>
                        <%= @member.email %> &middot; Verified
                      <% else %>
                        Not verified &middot; Earn 2&times; multiplier
                      <% end %>
                    </div>
                  </div>
                </div>
                <%= if @member.email_verified do %>
                  <span class="text-[10px] font-bold text-[#15803d] uppercase tracking-wider shrink-0">Verified &#10003;</span>
                <% else %>
                  <button phx-click="open_email_verification" class="bg-[#0a0a0a] text-white text-[11px] font-bold px-3 py-1.5 rounded-full hover:bg-[#1a1a22] transition-colors shrink-0 cursor-pointer">Verify</button>
                <% end %>
              </div>

              <%!-- Phone --%>
              <div class="px-6 py-4 flex items-center justify-between gap-3">
                <div class="flex items-center gap-3 min-w-0">
                  <div class={["w-9 h-9 rounded-full grid place-items-center shrink-0", if(@member.phone_verified, do: "bg-[#22C55E]", else: "bg-neutral-300")]}>
                    <svg class="w-4 h-4 text-white" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
                  </div>
                  <div class="min-w-0">
                    <div class="text-[13px] font-bold text-[#141414]">Phone</div>
                    <div class="text-[11px] text-neutral-500">
                      <%= if @member.phone_verified, do: "Verified", else: "Not verified · Earn 2× multiplier" %>
                    </div>
                  </div>
                </div>
                <%= if @member.phone_verified do %>
                  <span class="text-[10px] font-bold text-[#15803d] uppercase tracking-wider shrink-0">Verified &#10003;</span>
                <% else %>
                  <button phx-click="open_phone_verification" class="bg-[#0a0a0a] text-white text-[11px] font-bold px-3 py-1.5 rounded-full hover:bg-[#1a1a22] transition-colors shrink-0 cursor-pointer">Verify</button>
                <% end %>
              </div>
            </div>
          </div>

          <%!-- Danger zone --%>
          <div class="bg-white rounded-2xl border border-neutral-200/70 shadow-[0_1px_3px_rgba(0,0,0,0.04)] p-6">
            <div class="text-[10px] font-bold uppercase tracking-[0.14em] text-[#EF4444] mb-3">Danger zone</div>
            <div class="space-y-3">
              <button class="w-full text-left flex items-center justify-between text-[12px] text-neutral-600 hover:text-[#EF4444] transition-colors py-2 border-b border-neutral-100 cursor-pointer">
                <span>Export account data</span>
                <span>&darr;</span>
              </button>
              <a
                href={~p"/api/auth/session"}
                method="delete"
                data-confirm="Are you sure you want to disconnect your wallet and log out?"
                class="w-full text-left flex items-center justify-between text-[12px] text-neutral-600 hover:text-[#EF4444] transition-colors py-2 border-b border-neutral-100 cursor-pointer"
              >
                <span>Disconnect wallet</span>
                <span>&rarr;</span>
              </a>
              <button class="w-full text-left flex items-center justify-between text-[12px] text-[#EF4444] transition-colors py-2 cursor-pointer">
                <span>Deactivate account</span>
                <span>&rarr;</span>
              </button>
            </div>
          </div>
        </div>
      </div>
    </section>
  <% end %>
</main>

<%!-- Phone Verification Modal --%>
<%= if @show_phone_modal do %>
  <.live_component
    module={BlocksterV2Web.PhoneVerificationModalComponent}
    id="phone-verification-modal"
    current_user={@current_user}
    member={@member}
  />
<% end %>

<%!-- Email Verification Modal --%>
<%= if @show_email_modal do %>
  <.live_component
    module={BlocksterV2Web.EmailVerificationModalComponent}
    id="email-verification-modal"
    current_user={@current_user}
    member={@member}
  />
<% end %>

<% else %>
<%!-- ═══════════════════════════════════════════════
     PUBLIC MEMBER VIEW (member_public_mock.html)
═══════════════════════════════════════════════ --%>

<main class="ds-public-member max-w-[1280px] mx-auto px-6">

  <%!-- ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
       IDENTITY HERO — Public view
  ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ --%>
  <section class="pt-12 pb-10">
    <div class="grid grid-cols-12 gap-8 items-start">

      <div class="col-span-12 md:col-span-8">
        <div class="flex items-start gap-6">
          <BlocksterV2Web.DesignSystem.profile_avatar initials={user_initials(@member)} size="2xl" />
          <div class="flex-1 min-w-0">
            <div class="flex items-center gap-2 mb-2">
              <BlocksterV2Web.DesignSystem.eyebrow>Author profile</BlocksterV2Web.DesignSystem.eyebrow>
              <%= if @member.is_author do %>
                <span class="inline-flex items-center gap-1 bg-[#22C55E]/10 text-[#15803d] border border-[#22C55E]/25 px-2 py-0.5 rounded-full text-[10px] font-bold uppercase tracking-wider">
                  <svg class="w-3 h-3" viewBox="0 0 24 24" fill="currentColor"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41L9 16.17z"/></svg>
                  Verified writer
                </span>
              <% end %>
            </div>
            <h1 class="font-bold tracking-[-0.022em] leading-[0.96] text-[44px] md:text-[52px] text-[#141414] mb-2"><%= @member.username || "Anonymous" %></h1>
            <div class="flex items-center gap-2 text-[13px] text-neutral-500 font-medium mb-4">
              <span>@<%= @member.slug %></span>
              <span class="text-neutral-300">&middot;</span>
              <span>blockster.com/member/<%= @member.slug %></span>
              <span class="text-neutral-300">&middot;</span>
              <span>Member since <%= format_member_since(@member.inserted_at) %></span>
            </div>

            <%= if @member.bio do %>
              <p class="text-[15px] text-neutral-700 font-medium leading-relaxed max-w-[560px] mb-5"><%= @member.bio %></p>
            <% end %>

            <%!-- Social row (D17: no follow, D18: no RSS) --%>
            <div class="flex items-center gap-2 flex-wrap">
              <%!-- X handle from x_connection or user.x_handle --%>
              <% x_handle = cond do
                @x_connection && @x_connection.x_username -> @x_connection.x_username
                @member.x_handle -> @member.x_handle
                true -> nil
              end %>
              <%= if x_handle do %>
                <a href={"https://x.com/#{x_handle}"} target="_blank" rel="noopener" class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-white border border-neutral-200 hover:border-[#141414] transition-colors">
                  <svg class="w-3.5 h-3.5 text-neutral-600" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
                  <span class="text-[12px] font-medium text-[#141414]">@<%= x_handle %></span>
                </a>
              <% end %>
            </div>
          </div>
        </div>
      </div>

      <%!-- Right: Notify me + Share (Follow removed per D17) --%>
      <div class="col-span-12 md:col-span-4 flex flex-col gap-3 md:items-end">
        <div class="flex flex-wrap gap-2 md:justify-end">
          <button phx-click="notify_me" class="inline-flex items-center gap-2 bg-white border border-neutral-200 text-[#141414] px-4 py-2.5 rounded-full text-[12px] font-medium hover:border-[#141414] transition-colors cursor-pointer">
            <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/></svg>
            Notify me
          </button>
          <button id="member-share-btn" phx-hook="CopyToClipboard" data-copy-text={BlocksterV2Web.Endpoint.url() <> "/member/#{@member.slug}"} class="inline-flex items-center gap-2 bg-white border border-neutral-200 text-[#141414] px-3 py-2.5 rounded-full text-[12px] font-medium hover:border-[#141414] transition-colors cursor-pointer" title="Share profile link">
            <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/></svg>
          </button>
        </div>
      </div>
    </div>

    <%!-- Stats row (3 cards: Posts published, Total reads, BUX paid out — Followers removed per D17) --%>
    <div class="mt-10 grid grid-cols-2 md:grid-cols-3 gap-4">
      <div class="bg-white rounded-2xl border border-neutral-200/70 p-5 shadow-[0_1px_3px_rgba(0,0,0,0.04)]">
        <div class="text-[10px] font-bold tracking-[0.16em] uppercase text-[#9CA3AF] mb-2">Posts published</div>
        <div class="font-mono font-bold text-[32px] text-[#141414] leading-none"><%= compact_number(@post_count) %></div>
        <div class="text-[10px] text-neutral-500 font-medium mt-1.5">since <%= format_member_since(@member.inserted_at) %></div>
      </div>
      <div class="bg-white rounded-2xl border border-neutral-200/70 p-5 shadow-[0_1px_3px_rgba(0,0,0,0.04)]">
        <div class="text-[10px] font-bold tracking-[0.16em] uppercase text-[#9CA3AF] mb-2">Total reads</div>
        <div class="font-mono font-bold text-[32px] text-[#141414] leading-none"><%= compact_number(@total_reads) %></div>
        <div class="text-[10px] text-neutral-500 font-medium mt-1.5">all-time</div>
      </div>
      <div class="bg-white rounded-2xl border border-neutral-200/70 p-5 shadow-[0_1px_3px_rgba(0,0,0,0.04)]">
        <div class="text-[10px] font-bold tracking-[0.16em] uppercase text-[#9CA3AF] mb-2">BUX paid out</div>
        <div class="font-mono font-bold text-[32px] text-[#141414] leading-none"><%= compact_number(@total_bux_paid) %></div>
        <div class="text-[10px] text-neutral-500 font-medium mt-1.5">to readers</div>
      </div>
    </div>
  </section>
</main>

<%!-- ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
     TABS — Public view
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ --%>
<div class="ds-public-tabs border-y border-neutral-200/70 sticky top-[84px] z-[15]" style="background: rgba(250, 250, 249, 0.95); backdrop-filter: saturate(180%) blur(12px); -webkit-backdrop-filter: saturate(180%) blur(12px);">
  <div class="max-w-[1280px] mx-auto px-6 flex items-center gap-8 overflow-x-auto">
    <button phx-click="switch_tab" phx-value-tab="articles" class={"relative py-4 px-1 text-[14px] font-medium transition-colors cursor-pointer #{if @active_tab == "articles", do: "text-[#141414] font-bold", else: "text-[#6B7280] hover:text-[#141414]"}"}>
      Articles <span class="ml-1.5 font-mono text-[11px] opacity-50"><%= @post_count %></span>
      <%= if @active_tab == "articles" do %><span class="absolute bottom-0 left-0 right-0 h-0.5 bg-[#CAFC00]"></span><% end %>
    </button>
    <button phx-click="switch_tab" phx-value-tab="videos" class={"relative py-4 px-1 text-[14px] font-medium transition-colors cursor-pointer #{if @active_tab == "videos", do: "text-[#141414] font-bold", else: "text-[#6B7280] hover:text-[#141414]"}"}>
      Videos <span class="ml-1.5 font-mono text-[11px] opacity-50"><%= @video_count %></span>
      <%= if @active_tab == "videos" do %><span class="absolute bottom-0 left-0 right-0 h-0.5 bg-[#CAFC00]"></span><% end %>
    </button>
    <button phx-click="switch_tab" phx-value-tab="hubs" class={"relative py-4 px-1 text-[14px] font-medium transition-colors cursor-pointer #{if @active_tab == "hubs", do: "text-[#141414] font-bold", else: "text-[#6B7280] hover:text-[#141414]"}"}>
      Hubs <span class="ml-1.5 font-mono text-[11px] opacity-50"><%= length(@author_hubs) %></span>
      <%= if @active_tab == "hubs" do %><span class="absolute bottom-0 left-0 right-0 h-0.5 bg-[#CAFC00]"></span><% end %>
    </button>
    <button phx-click="switch_tab" phx-value-tab="about" class={"relative py-4 px-1 text-[14px] font-medium transition-colors cursor-pointer #{if @active_tab == "about", do: "text-[#141414] font-bold", else: "text-[#6B7280] hover:text-[#141414]"}"}>
      About
      <%= if @active_tab == "about" do %><span class="absolute bottom-0 left-0 right-0 h-0.5 bg-[#CAFC00]"></span><% end %>
    </button>
  </div>
</div>

<%!-- ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
     TAB CONTENT — Public view
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ --%>
<main class="max-w-[1280px] mx-auto px-6">

  <%!-- ARTICLES TAB (default) --%>
  <%= if @active_tab in ["articles", "videos"] do %>
    <section class="py-10">
      <div class="grid grid-cols-12 gap-8">

        <%!-- Posts grid --%>
        <div class="col-span-12 md:col-span-8">
          <div class="flex items-baseline justify-between mb-6">
            <div>
              <div class="text-[10px] font-bold tracking-[0.16em] uppercase text-[#9CA3AF] mb-1">
                <%= if @active_tab == "videos", do: "Video content", else: "All published stories" %>
              </div>
              <h2 class="font-bold tracking-[-0.018em] text-[24px] text-[#141414]">
                <%= if @active_tab == "videos", do: "Videos from #{@member.username || "this author"}", else: "Latest from #{@member.username || "this author"}" %>
              </h2>
            </div>
          </div>

          <%= if @posts == [] do %>
            <div class="bg-white rounded-2xl border border-neutral-200/70 p-12 text-center">
              <div class="text-neutral-400 text-[14px] font-medium">
                <%= if @active_tab == "videos", do: "No videos published yet", else: "No posts published yet" %>
              </div>
            </div>
          <% else %>
            <div class="space-y-5">
              <%= for post <- @posts do %>
                <a href={~p"/#{post.slug}"} class="ds-public-post-card block bg-white rounded-2xl border border-neutral-200/70 overflow-hidden transition-all duration-[250ms] hover:-translate-y-0.5 hover:shadow-[0_18px_30px_-12px_rgba(0,0,0,0.12)] hover:border-black/[0.12]">
                  <div class="grid grid-cols-[180px_1fr]">
                    <div class="bg-neutral-100">
                      <%= if post.featured_image do %>
                        <img src={BlocksterV2Web.ImageKit.w500_h500(post.featured_image)} alt="" class="w-full h-full object-cover" />
                      <% else %>
                        <div class="w-full h-full min-h-[120px] bg-neutral-100"></div>
                      <% end %>
                    </div>
                    <div class="p-5">
                      <%= if post.hub && Ecto.assoc_loaded?(post.hub) do %>
                        <div class="flex items-center gap-1.5 mb-2">
                          <div class={"w-3.5 h-3.5 rounded bg-gradient-to-br"} style={"background: linear-gradient(135deg, #{post.hub.color_primary || "#7D00FF"}, #{post.hub.color_secondary || "#4A00B8"})"}></div>
                          <span class="text-[9px] uppercase tracking-[0.12em] text-neutral-500 font-medium"><%= post.hub.name %></span>
                        </div>
                      <% end %>
                      <h3 class="font-bold text-[18px] text-[#141414] tracking-tight mb-2 leading-tight"><%= post.title %></h3>
                      <p class="text-[12px] text-neutral-500 font-medium leading-relaxed mb-3 line-clamp-2"><%= post.excerpt || "" %></p>
                      <div class="flex items-center justify-between text-[11px]">
                        <span class="text-neutral-500 font-medium"><%= reading_time(post) %> min · <%= compact_number(post.view_count || 0) %> reads · <%= format_post_time(post.published_at) %></span>
                        <%= if post.base_bux_reward && Decimal.compare(post.base_bux_reward, Decimal.new(0)) == :gt do %>
                          <div class="flex items-center gap-1 bg-[#CAFC00] text-black px-2 py-0.5 rounded-full font-bold text-[11px]">
                            <img src="https://ik.imagekit.io/blockster/blockster-icon.png" alt="" class="w-2.5 h-2.5 rounded-full" />
                            +<%= Decimal.to_integer(Decimal.round(post.base_bux_reward, 0)) %>
                          </div>
                        <% end %>
                      </div>
                    </div>
                  </div>
                </a>
              <% end %>
            </div>

            <%!-- Load more button --%>
            <% remaining = @post_count - length(@posts) %>
            <%= if remaining > 0 do %>
              <div class="mt-8 text-center">
                <button phx-click="load_more_posts" class="inline-flex items-center gap-2 bg-white border border-neutral-200 px-5 py-3 rounded-full text-[13px] font-bold text-[#141414] hover:border-[#141414] transition-colors cursor-pointer">
                  Load <%= remaining %> more <%= if @active_tab == "videos", do: "videos", else: "posts" %>
                </button>
              </div>
            <% end %>
          <% end %>
        </div>

        <%!-- Sidebar --%>
        <aside class="col-span-12 md:col-span-4 space-y-5">

          <%!-- Published in hubs (D19: live, uses post→hub relation) --%>
          <%= if @author_hubs != [] do %>
            <div class="bg-white rounded-2xl border border-neutral-200/70 p-6 shadow-[0_1px_3px_rgba(0,0,0,0.04)]">
              <div class="text-[10px] font-bold tracking-[0.16em] uppercase text-[#9CA3AF] mb-4">Published in</div>
              <div class="space-y-3">
                <%= for {hub, hub_post_count} <- @author_hubs do %>
                  <a href={~p"/hub/#{hub.slug}"} class="flex items-center gap-3 p-3 rounded-xl text-white relative overflow-hidden transition-all duration-[250ms] hover:-translate-y-[3px] hover:shadow-[0_18px_40px_-12px_rgba(0,0,0,0.35)]" style={"background: linear-gradient(135deg, #{hub.color_primary || "#7D00FF"} 0%, #{hub.color_secondary || "#4A00B8"} 100%)"}>
                    <div class="w-9 h-9 rounded-md bg-black/25 grid place-items-center shrink-0">
                      <%= if hub.logo_url do %>
                        <img src={BlocksterV2Web.ImageKit.w500_h500(hub.logo_url)} alt="" class="w-full h-full object-cover rounded-md" />
                      <% else %>
                        <span class="font-bold text-[11px]"><%= String.upcase(String.slice(hub.token || hub.name || "", 0, 3)) %></span>
                      <% end %>
                    </div>
                    <div class="flex-1 min-w-0">
                      <div class="text-[12px] font-bold leading-tight"><%= hub.name %></div>
                      <div class="text-[10px] text-white/70 font-mono mt-0.5"><%= hub_post_count %> stories</div>
                    </div>
                    <%!-- Radial glow overlay --%>
                    <div class="absolute inset-0 bg-[radial-gradient(circle_at_80%_20%,rgba(255,255,255,0.18),transparent_60%)] pointer-events-none"></div>
                  </a>
                <% end %>
              </div>
            </div>
          <% end %>

          <%!-- Recent activity sidebar --%>
          <div class="bg-white rounded-2xl border border-neutral-200/70 shadow-[0_1px_3px_rgba(0,0,0,0.04)] overflow-hidden">
            <div class="px-5 py-4 border-b border-neutral-100">
              <div class="text-[10px] font-bold tracking-[0.16em] uppercase text-[#9CA3AF]">Recent activity</div>
            </div>
            <div class="divide-y divide-neutral-100">
              <%!-- Show recent published posts as activity --%>
              <%= for post <- Enum.take(@posts, 4) do %>
                <div class="px-5 py-3 transition-colors hover:bg-black/[0.02]">
                  <div class="flex items-center gap-3">
                    <div class="w-7 h-7 rounded-lg bg-[#CAFC00]/15 border border-[#CAFC00]/30 grid place-items-center shrink-0">
                      <svg class="w-3.5 h-3.5 text-[#141414]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                    </div>
                    <div class="flex-1 min-w-0">
                      <div class="text-[12px] text-[#141414] font-medium">Published <span class="font-bold"><%= String.slice(post.title || "", 0, 30) %><%= if String.length(post.title || "") > 30, do: "…" %></span></div>
                      <div class="text-[10px] text-neutral-500 font-mono"><%= format_post_time(post.published_at) %></div>
                    </div>
                  </div>
                </div>
              <% end %>
              <%= if @posts == [] do %>
                <div class="px-5 py-6 text-center text-[12px] text-neutral-400 font-medium">No recent activity</div>
              <% end %>
            </div>
          </div>

        </aside>
      </div>
    </section>
  <% end %>

  <%!-- HUBS TAB --%>
  <%= if @active_tab == "hubs" do %>
    <section class="py-10">
      <div class="mb-6">
        <div class="text-[10px] font-bold tracking-[0.16em] uppercase text-[#9CA3AF] mb-1">Communities</div>
        <h2 class="font-bold tracking-[-0.018em] text-[24px] text-[#141414]">Hubs <%= @member.username || "this author" %> publishes in</h2>
      </div>
      <%= if @author_hubs == [] do %>
        <div class="bg-white rounded-2xl border border-neutral-200/70 p-12 text-center">
          <div class="text-neutral-400 text-[14px] font-medium">Not published in any hubs yet</div>
        </div>
      <% else %>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
          <%= for {hub, hub_post_count} <- @author_hubs do %>
            <a href={~p"/hub/#{hub.slug}"} class="relative overflow-hidden rounded-2xl p-6 text-white transition-all duration-[250ms] hover:-translate-y-[3px] hover:shadow-[0_18px_40px_-12px_rgba(0,0,0,0.35)]" style={"background: linear-gradient(135deg, #{hub.color_primary || "#7D00FF"} 0%, #{hub.color_secondary || "#4A00B8"} 100%)"}>
              <div class="flex items-center gap-3 mb-4">
                <div class="w-12 h-12 rounded-lg bg-black/25 grid place-items-center shrink-0">
                  <%= if hub.logo_url do %>
                    <img src={BlocksterV2Web.ImageKit.w500_h500(hub.logo_url)} alt="" class="w-full h-full object-cover rounded-lg" />
                  <% else %>
                    <span class="font-bold text-[14px]"><%= String.upcase(String.slice(hub.token || hub.name || "", 0, 3)) %></span>
                  <% end %>
                </div>
                <div>
                  <div class="font-bold text-[16px] leading-tight"><%= hub.name %></div>
                  <div class="text-[11px] text-white/70 font-mono mt-0.5"><%= hub_post_count %> stories published</div>
                </div>
              </div>
              <%= if hub.description do %>
                <p class="text-[12px] text-white/70 font-medium leading-relaxed line-clamp-2"><%= hub.description %></p>
              <% end %>
              <%!-- Radial glow overlay --%>
              <div class="absolute inset-0 bg-[radial-gradient(circle_at_80%_20%,rgba(255,255,255,0.18),transparent_60%)] pointer-events-none"></div>
            </a>
          <% end %>
        </div>
      <% end %>
    </section>
  <% end %>

  <%!-- ABOUT TAB --%>
  <%= if @active_tab == "about" do %>
    <section class="py-10">
      <div class="grid grid-cols-12 gap-8">
        <div class="col-span-12 md:col-span-8">
          <div class="text-[10px] font-bold tracking-[0.16em] uppercase text-[#9CA3AF] mb-1">About</div>
          <h2 class="font-bold tracking-[-0.018em] text-[24px] text-[#141414] mb-6"><%= @member.username || "Anonymous" %></h2>

          <%= if @member.bio do %>
            <div class="bg-white rounded-2xl border border-neutral-200/70 p-6 shadow-[0_1px_3px_rgba(0,0,0,0.04)] mb-5">
              <div class="text-[10px] font-bold tracking-[0.16em] uppercase text-[#9CA3AF] mb-3">Bio</div>
              <p class="text-[15px] text-neutral-700 font-medium leading-relaxed"><%= @member.bio %></p>
            </div>
          <% end %>

          <div class="bg-white rounded-2xl border border-neutral-200/70 p-6 shadow-[0_1px_3px_rgba(0,0,0,0.04)]">
            <div class="text-[10px] font-bold tracking-[0.16em] uppercase text-[#9CA3AF] mb-3">Details</div>
            <div class="space-y-3">
              <div class="flex items-center justify-between py-2 border-b border-neutral-100">
                <span class="text-[13px] text-neutral-500 font-medium">Username</span>
                <span class="text-[13px] text-[#141414] font-bold">@<%= @member.slug %></span>
              </div>
              <div class="flex items-center justify-between py-2 border-b border-neutral-100">
                <span class="text-[13px] text-neutral-500 font-medium">Member since</span>
                <span class="text-[13px] text-[#141414] font-mono"><%= format_member_since(@member.inserted_at) %></span>
              </div>
              <div class="flex items-center justify-between py-2 border-b border-neutral-100">
                <span class="text-[13px] text-neutral-500 font-medium">Posts published</span>
                <span class="text-[13px] text-[#141414] font-mono"><%= @post_count %></span>
              </div>
              <div class="flex items-center justify-between py-2">
                <span class="text-[13px] text-neutral-500 font-medium">Total reads</span>
                <span class="text-[13px] text-[#141414] font-mono"><%= compact_number(@total_reads) %></span>
              </div>
            </div>
          </div>

          <%!-- Social links --%>
          <% x_handle_about = cond do
            @x_connection && @x_connection.x_username -> @x_connection.x_username
            @member.x_handle -> @member.x_handle
            true -> nil
          end %>
          <%= if x_handle_about do %>
            <div class="bg-white rounded-2xl border border-neutral-200/70 p-6 shadow-[0_1px_3px_rgba(0,0,0,0.04)] mt-5">
              <div class="text-[10px] font-bold tracking-[0.16em] uppercase text-[#9CA3AF] mb-3">Social</div>
              <div class="flex items-center gap-2 flex-wrap">
                <a href={"https://x.com/#{x_handle_about}"} target="_blank" rel="noopener" class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-white border border-neutral-200 hover:border-[#141414] transition-colors">
                  <svg class="w-3.5 h-3.5 text-neutral-600" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
                  <span class="text-[12px] font-medium text-[#141414]">@<%= x_handle_about %></span>
                </a>
              </div>
            </div>
          <% end %>
        </div>

        <%!-- About tab sidebar: same hub cards --%>
        <aside class="col-span-12 md:col-span-4">
          <%= if @author_hubs != [] do %>
            <div class="bg-white rounded-2xl border border-neutral-200/70 p-6 shadow-[0_1px_3px_rgba(0,0,0,0.04)]">
              <div class="text-[10px] font-bold tracking-[0.16em] uppercase text-[#9CA3AF] mb-4">Published in</div>
              <div class="space-y-3">
                <%= for {hub, hub_post_count} <- @author_hubs do %>
                  <a href={~p"/hub/#{hub.slug}"} class="flex items-center gap-3 p-3 rounded-xl text-white relative overflow-hidden transition-all duration-[250ms] hover:-translate-y-[3px] hover:shadow-[0_18px_40px_-12px_rgba(0,0,0,0.35)]" style={"background: linear-gradient(135deg, #{hub.color_primary || "#7D00FF"} 0%, #{hub.color_secondary || "#4A00B8"} 100%)"}>
                    <div class="w-9 h-9 rounded-md bg-black/25 grid place-items-center shrink-0">
                      <%= if hub.logo_url do %>
                        <img src={BlocksterV2Web.ImageKit.w500_h500(hub.logo_url)} alt="" class="w-full h-full object-cover rounded-md" />
                      <% else %>
                        <span class="font-bold text-[11px]"><%= String.upcase(String.slice(hub.token || hub.name || "", 0, 3)) %></span>
                      <% end %>
                    </div>
                    <div class="flex-1 min-w-0">
                      <div class="text-[12px] font-bold leading-tight"><%= hub.name %></div>
                      <div class="text-[10px] text-white/70 font-mono mt-0.5"><%= hub_post_count %> stories</div>
                    </div>
                    <div class="absolute inset-0 bg-[radial-gradient(circle_at_80%_20%,rgba(255,255,255,0.18),transparent_60%)] pointer-events-none"></div>
                  </a>
                <% end %>
              </div>
            </div>
          <% end %>
        </aside>
      </div>
    </section>
  <% end %>

</main>

<% end %>
<%!-- ═══════════════════════════════════════════════
     END OF OWNER/PUBLIC CONDITIONAL
═══════════════════════════════════════════════ --%>

<BlocksterV2Web.DesignSystem.footer />
