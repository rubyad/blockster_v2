{
  "name": "blockster-settler",
  "version": "1.0.0",
  "description": "Blockster Solana settler service — BUX minting, bet settlement, airdrop operations",
  "main": "src/index.ts",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "create-token": "ts-node scripts/create-bux-token.ts",
    "mint-test": "ts-node scripts/mint-test-tokens.ts",
    "init-bankroll": "ts-node scripts/init-bankroll.ts",
    "init-bankroll-seed": "ts-node scripts/init-bankroll.ts --seed-liquidity",
    "init-airdrop": "ts-node scripts/init-airdrop.ts",
    "test": "ts-node tests/idl-consistency.test.ts && ts-node tests/pda-derivation.test.ts"
  },
  "dependencies": {
    "@coral-xyz/anchor": "^0.30.1",
    "@irys/sdk": "^0.2.11",
    "@metaplex-foundation/mpl-token-metadata": "^3.3.0",
    "@metaplex-foundation/umi": "^0.9.2",
    "@metaplex-foundation/umi-bundle-defaults": "^0.9.2",
    "@metaplex-foundation/umi-signer-wallet-adapters": "^0.9.2",
    "@solana/spl-token": "^0.4.9",
    "@solana/web3.js": "^1.98.0",
    "bs58": "^6.0.0",
    "dotenv": "^16.4.7",
    "express": "^4.21.2"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.12.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.3"
  }
}
