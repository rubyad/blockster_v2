# Elixir / Mix
/_build
/deps
/*.ez
.fetch

# Generated on crash by the VM
erl_crash.dump

# Generated on crash by NPM
npm-debug.log

# Static artifacts - you should commit these when using mix phx.digest
# /priv/static

# Since we are building assets from assets/,
# we ignore priv/static except for images directory
/priv/static/*
!/priv/static/images/
# Token metadata JSONs served at /<token>-metadata.json so Solana indexers
# (Solscan etc.) can resolve token name + logo. Listed in static_paths in
# lib/blockster_v2_web.ex — without un-ignoring here they'd 404 on prod.
!/priv/static/bux-metadata.json
!/priv/static/sol-lp-metadata.json
!/priv/static/bux-lp-metadata.json

# Environment files
.env
.env.*
!.env.example

# Database
*.db
*.db-*

# Test artifacts
/cover
/doc

# Ignore package tarball (built via "mix ecto.gen.migration").
blockster_v2-*.tar

# Ignore assets that are produced by build tools
assets/node_modules
**/node_modules

# Ignore digested assets cache
/priv/static/cache_manifest.json

# Git
.git/
.gitignore

# IDE
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
.elixir_ls/

# Logs
*.log
logs/

# Temporary files
/tmp
/temp

# Solana contracts — built + deployed separately, not part of the main app
# Dockerfile (which only copies mix.exs/mix.lock, config/, assets/, priv/,
# lib/, rel/). Excluding /contracts trims ~2.3GB of Rust build artifacts
# (target/) and Node modules (settler/node_modules) from the docker
# context upload — without this, deploys timed out on slow connections.
/contracts

# Sister project (lives in this repo for convenience but is its own Phoenix
# app — its own deploy, its own Dockerfile). 174MB of deps + node_modules
# unnecessary for the main app build.
/high-rollers-elixir

# Stray archive
/blockster_v2.zip
